      "visual_type": "none"
    },
    {
      "id": "LN_02",
      "section": "learn",
      "difficulty": 0,
      "type": "concept_card",
      "title": "Double the Double for ×4",
      "content": "To multiply by 4, first multiply by 2, then double again. Example: 4 × 6 → 2×6=12, then 12×2=24. So 4×6=24.",
      "cpa_phase": "concrete",
      "visual_type": "none"
    },
    {
