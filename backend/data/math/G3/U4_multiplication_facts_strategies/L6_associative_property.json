    {
      "id": "LN_01",
      "section": "learn",
      "difficulty": 0,
      "type": "concept_card",
      "title": "The Associative Property",
      "content": "When multiplying three numbers, you can change which two you multiply first. (2×3)×5 = 2×(3×5). Both = 30. The grouping changes, but the product doesn't.",
      "cpa_phase": "concrete",
      "visual_type": "none"
    },
    {
      "id": "LN_02",
      "section": "learn",
      "difficulty": 0,
      "type": "concept_card",
      "title": "Using Parentheses",
      "content": "Parentheses tell you what to do first. (4×2)×3: do 4×2=8 first, then 8×3=24. 4×(2×3): do 2×3=6 first, then 4×6=24. Same answer, different path.",
      "cpa_phase": "concrete",
      "visual_type": "none"
    },
    {
      "id": "LN_03",
      "section": "learn",
      "difficulty": 0,
      "type": "concept_card",
      "title": "Making Multiplication Easier",
      "content": "Group factors to make a ×10 fact. Example: 5 × 2 × 4. Group (5×2) first to get 10, then 10×4 = 40. Much easier than 5×8 = 40!",
      "cpa_phase": "pictorial",
      "visual_type": "manipulative",
      "visual_data": {
        "tool": "array_grid",
        "config": {
          "rows": 3,
          "cols": 4
        }
      }
    },
    {
      "id": "LN_04",
      "section": "learn",
      "difficulty": 0,
      "type": "concept_card",
      "title": "Associative vs. Commutative",
      "content": "Commutative changes the ORDER: 3×4 = 4×3. Associative changes the GROUPING: (3×4)×5 = 3×(4×5). Different properties, same big idea — the product stays the same.",
      "cpa_phase": "pictorial",
      "visual_type": "none"
    },
    {
