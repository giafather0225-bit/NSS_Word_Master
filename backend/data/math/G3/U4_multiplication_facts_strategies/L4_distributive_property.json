    { "id": "PT_04", "section": "pretest", "difficulty": 2, "question": "7 × 6 = 7 × (3 + 3). Find the product.", "choices": ["A. 21 + 21 = 42","B. 21 + 18 = 39","C. 14 + 14 = 28","D. 7 + 6 = 13"], "answer": "A", "explanation": "7×3=21, 7×3=21. 21+21=42." },
