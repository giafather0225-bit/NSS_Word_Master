    { "id": "LN_01", "section": "learn", "difficulty": 0, "type": "concept_card", "title": "The Distributive Property", "content": "You can break apart one factor into two smaller numbers, multiply each separately, then add. Example: 5 × 7 = 5 × (5+2) = (5×5)+(5×2) = 25+10 = 35." },
    { "id": "LN_02", "section": "learn", "difficulty": 0, "type": "concept_card", "title": "Breaking Apart with Arrays", "content": "Draw a 4×7 array. Split it into 4×4 and 4×3. Count each part: 16+12=28. The whole array has 28." },
    { "id": "LN_03", "section": "learn", "difficulty": 0, "type": "concept_card", "title": "Choosing How to Break Apart", "content": "Break the bigger factor into numbers you know well. If you know your 5s facts, break 7 into 5+2. If you know your doubles, break 8 into 4+4." },
