    { "id": "PT_02", "section": "pretest", "difficulty": 1, "question": "What does the Distributive Property let you do?", "choices": ["A. Change the order of factors","B. Break apart a factor and multiply in parts","C. Multiply by zero","D. Add instead of multiply"], "answer": "B", "explanation": "Break apart, multiply, then add." },
