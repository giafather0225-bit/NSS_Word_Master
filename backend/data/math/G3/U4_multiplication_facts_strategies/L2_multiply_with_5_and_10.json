      "visual_type": "none"
    },
    {
      "id": "LN_02",
      "section": "learn",
      "difficulty": 0,
      "type": "concept_card",
      "title": "Patterns for ×10",
      "content": "When you multiply by 10, just put a 0 at the end of the other number. 10 × 7 = 70. 10 × 3 = 30. Think of counting dimes!",
      "cpa_phase": "concrete",
      "visual_type": "none"
    },
    {
      "id": "LN_03",
      "section": "learn",
      "difficulty": 0,
      "type": "concept_card",
      "title": "×5 Is Half of ×10",
      "content": "Multiplying by 5 is half of multiplying by 10. If 10 × 6 = 60, then 5 × 6 = 30 (half of 60). This is a fast way to find ×5 facts when you already know ×10.",
      "cpa_phase": "pictorial",
      "visual_type": "none"
    },
    {
      "id": "LN_04",
      "section": "learn",
      "difficulty": 0,
      "type": "concept_card",
      "title": "Arrays for ×5 and ×10",
      "content": "An array of 5 rows by 4 dots shows 5 × 4 = 20. An array of 10 rows by 4 dots shows 10 × 4 = 40. Notice: doubling the number of rows from 5 to 10 doubles the product.",
