      "id": "LN_01",
      "section": "learn",
      "difficulty": 0,
      "type": "concept_card",
      "title": "Patterns for ×5",
      "content": "When you multiply by 5, the product always ends in 0 or 5. Skip count: 5, 10, 15, 20, 25, 30, 35, 40, 45, 50. Think of counting nickels!",
