      "visual_type": "none"
    },
    {
      "id": "LN_02",
      "section": "learn",
      "difficulty": 0,
      "type": "concept_card",
      "title": "Multiplying by 6: Double the ×3 Fact",
      "content": "Since 6 = 2 × 3, you can multiply by 3 first, then double. 6 × 5 → 3 × 5 = 15, then double 15 = 30. So 6 × 5 = 30.",
      "cpa_phase": "concrete",
      "visual_type": "none"
    },
    {
      "id": "LN_03",
      "section": "learn",
      "difficulty": 0,
      "type": "concept_card",
      "title": "Skip Counting by 6s",
      "content": "You can also skip count by 6: 6, 12, 18, 24, 30, 36, 42, 48, 54, 60. Notice: every ×6 product is exactly double the matching ×3 product.",
      "cpa_phase": "pictorial",
      "visual_type": "none"
    },
    {
      "id": "LN_04",
      "section": "learn",
      "difficulty": 0,
      "type": "concept_card",
      "title": "Arrays Show ×3 and ×6",
      "content": "An array of 3 rows × 5 columns has 15 dots (3 × 5). An array of 6 rows × 5 columns has 30 dots (6 × 5). The ×6 array is just two ×3 arrays stacked — that's why 6 × 5 is double 3 × 5.",
      "cpa_phase": "pictorial",
      "visual_type": "manipulative",
      "visual_data": {
        "tool": "array_grid",
        "config": {
          "rows": 6,
          "cols": 5
