    },
    {
      "id": "LN_05",
      "section": "learn",
      "difficulty": 0,
      "type": "concept_card",
      "title": "Split 6 Into 3 + 3",
      "content": "Another way to find ×6: split 6 into 3 + 3 and add. 6 × 7 = 3 × 7 + 3 × 7 = 21 + 21 = 42. This works because 6 groups of 7 is the same as two sets of 3 groups of 7.",
      "cpa_phase": "abstract",
      "visual_type": "none"
