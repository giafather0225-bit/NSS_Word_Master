    {
      "id": "LN_01",
      "section": "learn",
      "difficulty": 0,
      "type": "concept_card",
      "title": "Multiplying by 3",
      "content": "Skip count by 3: 3, 6, 9, 12, 15, 18, 21, 24, 27, 30. Or add the number three times: 3 × 4 = 4 + 4 + 4 = 12.",
