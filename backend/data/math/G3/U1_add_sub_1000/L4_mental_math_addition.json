  "learn": [
    {
      "id": "LEARN_01",
      "title": "What Is Mental Math?",
      "content": "Mental math means solving problems in your head — without paper, pencil, or a calculator. You use strategies that make numbers easier to work with. There are several strategies you can use for addition.",
      "cpa_phase": "concrete",
      "visual_type": "illustration",
      "visual_data": {
        "description": "A child thinking with a thought bubble showing 28+35, with arrows showing the number changing to 30+33"
      },
      "verification": "Go Math p.17 introduction"
    },
    {
      "id": "LEARN_02",
      "title": "Strategy 1: Count by Tens and Ones",
      "content": "Start with one number. Count on by tens for the tens digit of the other number. Then count on by ones. Example: 34 + 25. Start at 34. Count by tens: 44, 54. Count by ones: 55, 56, 57, 58, 59. So 34 + 25 = 59.",
      "cpa_phase": "pictorial",
      "visual_type": "number_line",
      "visual_data": {
        "start": 34,
        "jumps_tens": [
          44,
          54
        ],
        "jumps_ones": [
          55,
          56,
          57,
          58,
          59
        ],
        "result": 59
      },
      "verification": "Go Math p.17 — Count by tens and ones strategy"
    },
    {
      "id": "LEARN_03",
      "title": "Strategy 2: Friendly Numbers (Adjust)",
      "content": "Change one number to a 'friendly' number (a number ending in 0). Add, then adjust. Example: 17 + 25. Change 17 to 20 (add 3). 20 + 25 = 45. Adjust: 45 - 3 = 42. So 17 + 25 = 42.",
      "cpa_phase": "pictorial",
      "visual_type": "diagram",
      "visual_data": {
        "original": "17 + 25",
        "friendly": "20 + 25 = 45",
        "adjust": "45 - 3 = 42"
      },
      "verification": "Go Math p.17 — Friendly numbers example with 17+25=42"
    },
    {
      "id": "LEARN_04",
      "title": "Strategy 3: Break Apart (Place Value)",
      "content": "Break each number into hundreds, tens, and ones. Add each place separately. Example: 116 + 203. Hundreds: 100 + 200 = 300. Tens and ones: 16 + 3 = 19. Total: 300 + 19 = 319.",
      "cpa_phase": "pictorial",
      "visual_type": "place_value_chart",
      "visual_data": {
        "numbers": [
          116,
          203
        ],
        "hundreds": "100+200=300",
        "tens_ones": "16+3=19",
        "total": 319
      },
      "verification": "Go Math p.19 Q7 — break apart with 116+203"
    },
    {
      "id": "LEARN_05",
      "title": "Strategy 4: Make a Ten",
      "content": "Move a small amount from one number to the other to make a ten. Example: 28 + 35. Take 2 from 35 and give it to 28: 30 + 33 = 63. Or: add 2 to 28 to make 30, then 30 + 35 = 65, then subtract 2: 65 - 2 = 63.",
      "cpa_phase": "abstract",
      "visual_type": "diagram",
      "visual_data": {
        "original": "28 + 35",
        "method1": "30 + 33 = 63",
        "method2": "30 + 35 = 65, 65 - 2 = 63"
      },
      "verification": "Go Math p.18 Q6 — make a ten with 28+35"
    },
    {
      "id": "LEARN_06",
      "title": "Choosing the Best Strategy",
      "content": "Different problems work best with different strategies. Count by tens and ones: good for small addends. Friendly numbers: good when one number is close to a ten. Break apart: good for 3-digit numbers. Make a ten: good when one number ends in 8 or 9.",
      "cpa_phase": "abstract",
      "visual_type": "comparison_table",
      "visual_data": {
        "strategies": [
          "Count by tens/ones",
          "Friendly numbers",
          "Break apart",
          "Make a ten"
        ],
        "best_for": [
          "small numbers",
          "near a ten",
          "3-digit",
          "ends in 8 or 9"
        ]
      },
      "verification": "Go Math p.17-19 strategy overview"
    },
    {
      "id": "LEARN_07",
      "title": "Mental Math with 3-Digit Numbers",
      "content": "You can use mental math with bigger numbers too! Example: 376 + 427. Break apart: 300 + 400 = 700. 76 + 27 = 103. 700 + 103 = 803. So 376 + 427 = 803.",
      "cpa_phase": "abstract",
      "visual_type": "text",
      "visual_data": {},
      "verification": "Go Math p.19 Q9 — concert attendance 376+427"
    },
    {
      "id": "LEARN_08",
      "title": "Key Idea Summary",
      "content": "Mental math strategies for addition: 1) Count by tens and ones — jump along a number line. 2) Friendly numbers — change to a nearby ten, add, adjust back. 3) Break apart — add hundreds, tens, and ones separately. 4) Make a ten — shift amounts between numbers to create a ten. Choose the strategy that makes the problem easiest for you!",
      "cpa_phase": "abstract",
      "visual_type": "summary_card",
      "visual_data": {},
      "verification": "Go Math pp.17-20 lesson summary"
    }
  ],
