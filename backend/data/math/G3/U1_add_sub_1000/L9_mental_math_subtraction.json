  "learn": [
    {
      "id": "LEARN_01", "type": "concept_card",
      "title": "Strategy 1: Count Up",
      "content": "Start at the smaller number. Count up by tens, then by ones, to reach the bigger number. Example: 62−39. Start at 39. Count up: 39→49→59 (that's +20), 59→60→61→62 (that's +3). So 62−39=23.",
      "visual_type": "number_line", "cpa_phase": "pictorial"
    },
    {
      "id": "LEARN_02", "type": "concept_card",
      "title": "Strategy 2: Take Away Tens and Ones",
      "content": "Start at the bigger number. Subtract the tens, then the ones. Example: 62−39. Start at 62. Take away 30: 62→32. Take away 9: 32→23. So 62−39=23.",
      "visual_type": "number_line", "cpa_phase": "pictorial"
    },
    {
      "id": "LEARN_03", "type": "concept_card",
      "title": "Strategy 3: Use Friendly Numbers",
      "content": "Change the number you're subtracting to a 'friendly' number (like a multiple of 10). Example: 74−39. Think: 39 is close to 40. 74−40=34. But you subtracted 1 too many, so add 1 back: 34+1=35.",
      "visual_type": "step_by_step", "cpa_phase": "abstract"
    },
    {
      "id": "LEARN_04", "type": "concept_card",
      "title": "When to Use Each Strategy",
      "content": "Count Up works best when the two numbers are close together (like 62−58). Take Away works well for any subtraction. Friendly Numbers work best when one number is close to a ten or hundred (like 99, 198, 301).",
      "visual_type": "comparison_table", "cpa_phase": "abstract"
    },
    {
      "id": "LEARN_05", "type": "concept_card",
      "title": "Example: 285 − 99",
      "content": "99 is close to 100. Use friendly numbers: 285−100=185. You subtracted 1 too many, so add back 1: 185+1=186. Answer: 285−99=186.",
      "visual_type": "step_by_step", "cpa_phase": "abstract",
      "example": { "problem": "285−99", "friendly": "285−100=185", "adjust": "+1", "answer": 186 }
    },
    {
      "id": "LEARN_06", "type": "concept_card",
      "title": "Example: 357 − 214",
      "content": "Take Away strategy: 357−200=157, 157−10=147, 147−4=143. Answer: 357−214=143.",
      "visual_type": "step_by_step", "cpa_phase": "abstract",
      "example": { "problem": "357−214", "steps": ["357−200=157", "157−10=147", "147−4=143"], "answer": 143 }
    },
    {
      "id": "LEARN_07", "type": "concept_card",
      "title": "Number Line Visual",
      "content": "A number line helps you see the jumps. For 74−39: Draw a line. Mark 39. Jump +1 to 40. Jump +30 to 70. Jump +4 to 74. Total jumps: 1+30+4=35.",
      "visual_type": "number_line", "cpa_phase": "pictorial"
    },
    {
      "id": "LEARN_08", "type": "concept_card",
      "title": "Common Mistake Alert!",
      "content": "When using friendly numbers, remember to ADJUST! If you subtract more than needed, ADD back. If you subtract less than needed, SUBTRACT more. Example: 74−39. Subtract 40 (1 too many) → add 1 back.",
      "visual_type": "error_highlight", "cpa_phase": "abstract"
    }
  ],

