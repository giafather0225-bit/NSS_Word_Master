  "learn": [
    {
      "id": "LEARN_01",
      "title": "The Place Value Algorithm",
      "content": "The place value method for addition means lining up numbers by their place values (ones, tens, hundreds) and adding each column from right to left. When a column adds to 10 or more, you regroup.",
      "cpa_phase": "concrete",
      "visual_type": "illustration",
      "visual_data": {
        "description": "Base-ten blocks being combined, with regrouping shown as 10 ones being traded for 1 ten rod"
      },
      "verification": "Go Math p.29 introduction"
    },
    {
      "id": "LEARN_02",
      "title": "Step 1: Add the Ones",
      "content": "Line up the numbers vertically. Start with the ones column. Example: 356 + 218. Ones: 6+8=14. Since 14≥10, write 4 in the ones place and regroup 1 ten to the tens column.",
      "cpa_phase": "pictorial",
      "visual_type": "column_addition",
      "visual_data": {
        "problem": "356+218",
        "step": "ones",
        "sum": 14,
        "write": 4,
        "carry": 1
      },
      "verification": "Go Math p.29 Step 1"
    },
    {
      "id": "LEARN_03",
      "title": "Step 2: Add the Tens",
      "content": "Now add the tens column, including any regrouped ten. Example: 356 + 218. Tens: 5+1+1(carried)=7. Write 7 in the tens place. No regrouping needed here.",
      "cpa_phase": "pictorial",
      "visual_type": "column_addition",
      "visual_data": {
        "problem": "356+218",
        "step": "tens",
        "sum": 7,
        "write": 7,
        "carry": 0
      },
      "verification": "Go Math p.29 Step 2"
    },
    {
      "id": "LEARN_04",
      "title": "Step 3: Add the Hundreds",
      "content": "Finally add the hundreds column. Example: 356 + 218. Hundreds: 3+2=5. Write 5. The answer is 574. Check with estimate: 400+200=600. Is 574 close? Yes!",
      "cpa_phase": "pictorial",
      "visual_type": "column_addition",
      "visual_data": {
        "problem": "356+218",
        "step": "hundreds",
        "sum": 5,
        "answer": 574
      },
      "verification": "Go Math p.29-30 Step 3"
    },
    {
      "id": "LEARN_05",
      "title": "Regrouping Tens to Hundreds",
      "content": "Sometimes the tens add to 10 or more. Example: 472 + 361. Ones: 2+1=3. Tens: 7+6=13. Write 3 tens, regroup 1 hundred. Hundreds: 4+3+1=8. Answer: 833.",
      "cpa_phase": "pictorial",
      "visual_type": "column_addition",
      "visual_data": {
        "problem": "472+361",
        "tens_sum": 13,
        "carry_to_hundreds": 1,
        "answer": 833
      },
      "verification": "Go Math p.30 — regrouping tens"
    },
    {
      "id": "LEARN_06",
      "title": "Double Regrouping",
      "content": "Some problems need regrouping in both ones and tens! Example: 487 + 356. Ones: 7+6=13 → write 3, carry 1. Tens: 8+5+1=14 → write 4, carry 1. Hundreds: 4+3+1=8. Answer: 843.",
      "cpa_phase": "abstract",
      "visual_type": "column_addition",
      "visual_data": {
        "problem": "487+356",
        "ones_carry": 1,
        "tens_carry": 1,
        "answer": 843
      },
      "verification": "Go Math p.30 — double regrouping"
    },
    {
      "id": "LEARN_07",
      "title": "Adding Three Numbers",
      "content": "You can use the same steps with three addends. Example: 140 + 457 + 301. Ones: 0+7+1=8. Tens: 4+5+0=9. Hundreds: 1+4+3=8. Answer: 898. Estimate: 150+450+300=900. Close!",
      "cpa_phase": "abstract",
      "visual_type": "column_addition",
      "visual_data": {
        "problem": "140+457+301",
        "answer": 898,
        "estimate": 900
      },
      "verification": "Go Math p.30 — Model example with three addends"
    },
    {
      "id": "LEARN_08",
      "title": "Key Idea Summary",
      "content": "Use place value to add: 1) Estimate first. 2) Line up by place value. 3) Add ones — regroup if 10 or more. 4) Add tens — regroup if 10 or more. 5) Add hundreds. 6) Check: Is your answer close to the estimate?",
      "cpa_phase": "abstract",
      "visual_type": "summary_card",
      "visual_data": {},
      "verification": "Go Math pp.29-32 lesson summary"
    }
  ],
