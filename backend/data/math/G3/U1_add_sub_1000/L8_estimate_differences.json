  "learn": [
    {
      "id": "LEARN_01",
      "type": "concept_card",
      "title": "What Does 'Estimate' Mean?",
      "content": "When a problem says 'about' or 'estimate,' you don't need the exact answer. You find a number that is close to the exact answer.",
      "visual_type": "text_with_icon",
      "cpa_phase": "concrete"
    },
    {
      "id": "LEARN_02",
      "type": "concept_card",
      "title": "Method 1: Compatible Numbers",
      "content": "Compatible numbers are numbers that are easy to compute mentally. To estimate 431 − 398: change 431→425 and 398→400. Then 425 − 400 = 25. The estimated difference is about 25.",
      "visual_type": "step_by_step",
      "cpa_phase": "pictorial",
      "example": {
        "problem": "431 − 398",
        "compatible": "425 − 400",
        "estimate": 25
      }
    },
    {
      "id": "LEARN_03",
      "type": "concept_card",
      "title": "Method 2: Rounding to the Nearest Ten",
      "content": "Round each number to the nearest ten, then subtract. Example: 762 − 332 → 760 − 330 = 430. The estimated difference is about 430.",
      "visual_type": "number_line",
      "cpa_phase": "pictorial",
      "example": {
        "problem": "762 − 332",
        "rounded": "760 − 330",
        "estimate": 430
      }
    },
    {
      "id": "LEARN_04",
      "type": "concept_card",
      "title": "Method 2: Rounding to the Nearest Hundred",
      "content": "Round each number to the nearest hundred, then subtract. Example: 762 − 332 → 800 − 300 = 500. The estimated difference is about 500.",
      "visual_type": "place_value_chart",
      "cpa_phase": "pictorial",
      "example": {
        "problem": "762 − 332",
        "rounded": "800 − 300",
        "estimate": 500
      }
    },
    {
      "id": "LEARN_05",
      "type": "concept_card",
      "title": "Which Method Is Better?",
      "content": "It depends! Rounding to the nearest ten usually gives a closer estimate. Rounding to the nearest hundred is faster. Compatible numbers can be the most accurate when you choose wisely. Actual: 762 − 332 = 430. Nearest ten: 430. Nearest hundred: 500.",
      "visual_type": "comparison_table",
      "cpa_phase": "abstract"
    },
    {
      "id": "LEARN_06",
      "type": "concept_card",
      "title": "When NOT to Round to Hundreds",
      "content": "If both numbers round to the same hundred, your estimate would be 0! Example: 436 − 412 → 400 − 400 = 0. That's not useful! Use tens instead: 440 − 410 = 30.",
      "visual_type": "warning_example",
      "cpa_phase": "abstract",
      "example": {
        "problem": "436 − 412",
        "bad_estimate": "400 − 400 = 0",
        "better_estimate": "440 − 410 = 30"
      }
    },
    {
      "id": "LEARN_07",
      "type": "concept_card",
      "title": "Real-World Example: Yellowfin Tuna",
      "content": "A yellowfin tuna weighs 431 pounds. A grouper weighs 398 pounds. About how much heavier is the tuna? Use compatible numbers: 425 − 400 = 25. The tuna is about 25 pounds heavier.",
      "visual_type": "illustration",
      "cpa_phase": "concrete",
      "example": {
        "tuna": 431,
        "grouper": 398,
        "compatible": "425 − 400",
        "estimate": 25
      }
    },
    {
      "id": "LEARN_08",
      "type": "concept_card",
      "title": "Common Mistake Alert!",
      "content": "Don't add when you should subtract! If the problem says 'how many more' or 'how much heavier' or 'how many left,' you need to SUBTRACT.",
      "visual_type": "error_highlight",
      "cpa_phase": "abstract"
    }
  ],
