  "learn": [
    {
      "id": "LEARN_01",
      "title": "What Is the Break Apart Strategy?",
      "content": "The break apart strategy means splitting numbers by place value — hundreds, tens, and ones — and adding each place separately. Then you combine the partial sums to get the total.",
      "cpa_phase": "concrete",
      "visual_type": "illustration",
      "visual_data": {
        "description": "Base-ten blocks showing 355 (3 flats, 5 rods, 5 units) and 414 (4 flats, 1 rod, 4 units) being combined"
      },
      "verification": "Go Math p.25 introduction"
    },
    {
      "id": "LEARN_02",
      "title": "Step 1: Estimate First",
      "content": "Always estimate before you add. This helps you check if your answer makes sense. Example: 355 + 414. Estimate: 400 + 400 = 800. Your exact answer should be close to 800.",
      "cpa_phase": "abstract",
      "visual_type": "text",
      "visual_data": {},
      "verification": "Go Math p.25 Step 1"
    },
    {
      "id": "LEARN_03",
      "title": "Step 2: Break Apart the Addends",
      "content": "Break each number into hundreds, tens, and ones. Then add each place value. 355 + 414: Hundreds: 300 + 400 = 700. Tens: 50 + 10 = 60. Ones: 5 + 4 = 9.",
      "cpa_phase": "pictorial",
      "visual_type": "place_value_chart",
      "visual_data": {
        "number1": {
          "H": 300,
          "T": 50,
          "O": 5
        },
        "number2": {
          "H": 400,
          "T": 10,
          "O": 4
        },
        "sums": {
          "H": 700,
          "T": 60,
          "O": 9
        }
      },
      "verification": "Go Math p.25-26 Step 2"
    },
    {
      "id": "LEARN_04",
      "title": "Step 3: Add the Partial Sums",
      "content": "Combine the sums from each place value. 700 + 60 + 9 = 769. Check: Is 769 close to the estimate of 800? Yes! So the answer is reasonable.",
      "cpa_phase": "abstract",
      "visual_type": "equation",
      "visual_data": {
        "equation": "700 + 60 + 9 = 769"
      },
      "verification": "Go Math p.26 Step 3"
    },
    {
      "id": "LEARN_05",
      "title": "When Digits Add to More Than 9 (Regrouping)",
      "content": "Sometimes when you add ones or tens, you get more than 9. Example: 257 + 168. Hundreds: 200+100=300. Tens: 50+60=110. Ones: 7+8=15. Now add: 300+110+15=425. The 110 means 1 hundred and 1 ten. The 15 means 1 ten and 5 ones.",
      "cpa_phase": "pictorial",
      "visual_type": "place_value_chart",
      "visual_data": {
        "number1": {
          "H": 200,
          "T": 50,
          "O": 7
        },
        "number2": {
          "H": 100,
          "T": 60,
          "O": 8
        },
        "sums": {
          "H": 300,
          "T": 110,
          "O": 15
        },
        "total": 425
      },
      "verification": "Go Math p.26 — regrouping concept"
    },
    {
      "id": "LEARN_06",
      "title": "Break Apart with Larger Sums",
      "content": "Example: 476 + 385. Hundreds: 400+300=700. Tens: 70+80=150. Ones: 6+5=11. Total: 700+150+11=861. Estimate check: 500+400=900. Is 861 close to 900? Yes!",
      "cpa_phase": "abstract",
      "visual_type": "step_by_step",
      "visual_data": {
        "steps": [
          "400+300=700",
          "70+80=150",
          "6+5=11",
          "700+150+11=861"
        ]
      },
      "verification": "Go Math p.26-27 — regrouping in multiple places"
    },
    {
      "id": "LEARN_07",
      "title": "Why Estimate and Break Apart Together?",
      "content": "Estimating first gives you a 'target.' If your break apart answer is far from the estimate, you probably made an error. Example: 283 + 541. Estimate: 300+500=800. Break apart: 200+500=700, 80+40=120, 3+1=4. Total: 700+120+4=824. 824 is close to 800 ✓.",
      "cpa_phase": "abstract",
      "visual_type": "text",
      "visual_data": {},
      "verification": "Go Math p.25-27 — estimate then compute pattern"
    },
    {
      "id": "LEARN_08",
      "title": "Key Idea Summary",
      "content": "The break apart strategy: 1) Estimate first. 2) Break each number into hundreds, tens, and ones. 3) Add each place value separately to get partial sums. 4) Combine the partial sums. 5) Check: Is your answer close to the estimate? This strategy works for any 3-digit addition!",
      "cpa_phase": "abstract",
      "visual_type": "summary_card",
      "visual_data": {},
      "verification": "Go Math pp.25-28 lesson summary"
    }
  ],
