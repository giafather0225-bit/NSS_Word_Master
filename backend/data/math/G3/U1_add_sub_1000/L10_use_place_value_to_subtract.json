  "learn": [
    {
      "id": "LEARN_01",
      "type": "concept_card",
      "title": "Place Value Review",
      "content": "Every 3-digit number has hundreds, tens, and ones. 585 = 5 hundreds + 8 tens + 5 ones. To subtract, we work from right to left: ones first, then tens, then hundreds.",
      "visual_type": "place_value_chart",
      "cpa_phase": "concrete"
    },
    {
      "id": "LEARN_02",
      "type": "concept_card",
      "title": "Step 1: Subtract the Ones",
      "content": "Look at the ones place. Can you subtract? If the top digit is smaller, you need to REGROUP. Example: 585−119. Ones: 5−9? Can't do it! Regroup: take 1 ten → now 7 tens and 15 ones. 15−9=6.",
      "visual_type": "step_by_step",
      "cpa_phase": "pictorial"
    },
    {
      "id": "LEARN_03",
      "type": "concept_card",
      "title": "Step 2: Subtract the Tens",
      "content": "After regrouping (if needed), subtract the tens. 585−119: We now have 7 tens. 7−1=6 tens.",
      "visual_type": "step_by_step",
      "cpa_phase": "pictorial"
    },
    {
      "id": "LEARN_04",
      "type": "concept_card",
      "title": "Step 3: Subtract the Hundreds",
      "content": "Subtract the hundreds place. 585−119: 5−1=4 hundreds. Final answer: 466.",
      "visual_type": "step_by_step",
      "cpa_phase": "pictorial"
    },
    {
      "id": "LEARN_05",
      "type": "concept_card",
      "title": "Double Regrouping",
      "content": "Sometimes you regroup TWICE! Example: 651−376. Ones: 1−6? Regroup → 11−6=5. Tens: 4−7? Regroup again → 14−7=7. Hundreds: 5−3=2. Answer: 275.",
      "visual_type": "step_by_step",
      "cpa_phase": "pictorial"
    },
    {
      "id": "LEARN_06",
      "type": "concept_card",
      "title": "Always Estimate First!",
      "content": "Before subtracting, estimate to check if your answer makes sense. 585−119: estimate 600−100=500. Your answer (466) is close to 500. Makes sense!",
      "visual_type": "comparison_table",
      "cpa_phase": "abstract"
    },
    {
      "id": "LEARN_07",
      "type": "concept_card",
      "title": "Check Your Work: Add Back!",
      "content": "To check subtraction, add your answer to the number you subtracted. If it equals the starting number, you're correct! 466+119=585 ✓",
      "visual_type": "step_by_step",
      "cpa_phase": "abstract"
    },
    {
      "id": "LEARN_08",
      "type": "concept_card",
      "title": "Common Mistake: Forgetting to Regroup",
      "content": "DON'T subtract the smaller digit from the larger one in the wrong direction! 585−119: the ones column is NOT 9−5=4. It's 15−9=6 (after regrouping).",
      "visual_type": "error_highlight",
      "cpa_phase": "abstract"
    }
  ],
