  "learn": [
    {
      "id": "LEARN_01",
      "title": "What Is Estimating?",
      "content": "Sometimes you don't need an exact answer. An estimate is a number close to the exact answer. When you estimate a sum, you find about how much two numbers add up to.",
      "cpa_phase": "concrete",
      "visual_type": "illustration",
      "visual_data": {
        "description": "A child at a store with items priced $3.85 and $5.12. Thought bubble: About $4 + $5 = about $9. I have $10, so I have enough!"
      },
      "verification": "Go Math p.13 introduction"
    },
    {
      "id": "LEARN_02",
      "title": "Method 1: Rounding",
      "content": "To estimate a sum by rounding: 1) Round each number to the same place (nearest ten or nearest hundred). 2) Add the rounded numbers. Example: 367 + 512. Round to hundreds: 400 + 500 = 900. So 367 + 512 is about 900.",
      "cpa_phase": "pictorial",
      "visual_type": "number_line",
      "visual_data": {
        "numbers": [
          367,
          512
        ],
        "rounded": [
          400,
          500
        ],
        "place": "hundreds",
        "sum": 900
      },
      "verification": "Go Math p.13 Model — Rounding method"
    },
    {
      "id": "LEARN_03",
      "title": "Method 2: Compatible Numbers",
      "content": "Compatible numbers are numbers that are easy to compute mentally. They are close to the actual numbers but simpler. Example: 367 + 512. Use compatible numbers: 375 + 525 = 900. So 367 + 512 is about 900.",
      "cpa_phase": "pictorial",
      "visual_type": "diagram",
      "visual_data": {
        "original": [
          367,
          512
        ],
        "compatible": [
          375,
          525
        ],
        "sum": 900
      },
      "verification": "Go Math p.13 Model — Compatible numbers method"
    },
    {
      "id": "LEARN_04",
      "title": "Rounding Two-Digit Numbers to Estimate",
      "content": "For two-digit numbers, round to the nearest ten. Example: 27 + 78. Round: 30 + 80 = 110. So 27 + 78 is about 110. The exact answer is 105. The estimate 110 is close!",
      "cpa_phase": "pictorial",
      "visual_type": "number_line",
      "visual_data": {
        "numbers": [
          27,
          78
        ],
        "rounded": [
          30,
          80
        ],
        "place": "tens",
        "sum": 110
      },
      "verification": "Go Math p.14 Q8"
    },
    {
      "id": "LEARN_05",
      "title": "Rounding Three-Digit Numbers to Estimate",
      "content": "For three-digit numbers, round to the nearest hundred. Example: 186 + 460. Round: 200 + 500 = 700. So 186 + 460 is about 700. The exact answer is 646. The estimate 700 is a good approximation.",
      "cpa_phase": "abstract",
      "visual_type": "text",
      "visual_data": {},
      "verification": "Go Math p.15 Q11"
    },
    {
      "id": "LEARN_06",
      "title": "Choosing the Best Method",
      "content": "Both rounding and compatible numbers give good estimates. Sometimes one method gives a closer estimate than the other. Example: 278 + 369. Rounding: 300 + 400 = 700. Compatible: 275 + 325 = 600. Exact: 647. Here, compatible numbers (600) are closer to the exact answer (647).",
      "cpa_phase": "abstract",
      "visual_type": "comparison_table",
      "visual_data": {
        "methods": [
          "Rounding",
          "Compatible"
        ],
        "estimates": [
          700,
          600
        ],
        "exact": 647
      },
      "verification": "Go Math p.15 Q14"
    },
    {
      "id": "LEARN_07",
      "title": "Using Estimation in Word Problems",
      "content": "Estimation helps when you need a quick answer. Example: A store sold 238 pet bowls in June and 345 in July. About how many were sold in both months? Round: 200 + 300 = 500. About 500 pet bowls were sold.",
      "cpa_phase": "abstract",
      "visual_type": "word_problem",
      "visual_data": {
        "context": "Pet store sales table"
      },
      "verification": "Go Math p.16 Q16-18"
    },
    {
      "id": "LEARN_08",
      "title": "Key Idea Summary",
      "content": "To estimate sums: Rounding — round each number to the nearest ten or hundred, then add. Compatible numbers — replace each number with a close number that is easy to add. Both methods give a number close to the exact answer. Use the word 'about' when you estimate.",
      "cpa_phase": "abstract",
      "visual_type": "summary_card",
      "visual_data": {},
      "verification": "Go Math pp.13-16 lesson summary"
    }
  ],
