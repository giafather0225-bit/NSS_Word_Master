  "learn": [
    {
      "id": "LEARN_01",
      "title": "Adding More Than Two Numbers",
      "content": "Sometimes you need to add three or more numbers. You can use addition properties to make this easier. Properties are rules that are always true.",
      "cpa_phase": "concrete",
      "visual_type": "illustration",
      "visual_data": {
        "description": "Three groups of objects (apples, peaches, bananas) being combined"
      },
      "verification": "Go Math p.21 introduction"
    },
    {
      "id": "LEARN_02",
      "title": "Commutative Property (Order Property)",
      "content": "The Commutative Property says you can add numbers in any order and get the same sum. Example: 4 + 7 = 7 + 4. Both equal 11. This helps because you can rearrange numbers to find easier pairs.",
      "cpa_phase": "pictorial",
      "visual_type": "equation_pair",
      "visual_data": {
        "left": "4 + 7 = 11",
        "right": "7 + 4 = 11",
        "property": "Commutative"
      },
      "verification": "Go Math p.21 — Commutative Property review"
    },
    {
      "id": "LEARN_03",
      "title": "Associative Property (Grouping Property)",
      "content": "The Associative Property says you can group addends differently and get the same sum. Example: (5 + 3) + 7 = 5 + (3 + 7). Left: 8 + 7 = 15. Right: 5 + 10 = 15. Same answer! Grouping 3 + 7 first makes a friendly 10.",
      "cpa_phase": "pictorial",
      "visual_type": "equation_pair",
      "visual_data": {
        "left": "(5+3)+7 = 8+7 = 15",
        "right": "5+(3+7) = 5+10 = 15",
        "property": "Associative"
      },
      "verification": "Go Math p.21 — Associative Property definition"
    },
    {
      "id": "LEARN_04",
      "title": "Identity Property",
      "content": "The Identity Property says that adding 0 to any number gives that same number. Example: 42 + 0 = 42. Zero is the 'identity' element for addition because it doesn't change the number.",
      "cpa_phase": "abstract",
      "visual_type": "equation",
      "visual_data": {
        "equation": "42 + 0 = 42"
      },
      "verification": "Go Math p.21 — Identity Property"
    },
    {
      "id": "LEARN_05",
      "title": "Using Properties Together: Example",
      "content": "Find 36 + 37 + 51. Step 1: Line up by place value. Step 2: Look for friendly groups. 37 + 51: 7 + 1 = 8 (easy ones). Step 3: Change grouping → 36 + (37 + 51) = 36 + 88 = 124. Or reorder: (36 + 51) + 37 = 87 + 37 = 124.",
      "cpa_phase": "abstract",
      "visual_type": "step_by_step",
      "visual_data": {
        "steps": [
          "36 + 37 + 51",
          "Regroup: 36 + (37+51)",
          "37+51 = 88",
          "36 + 88 = 124"
        ]
      },
      "verification": "Go Math p.22 — Model example 36+37+51"
    },
    {
      "id": "LEARN_06",
      "title": "Strategy: Look for Tens",
      "content": "When adding 3 or more numbers, look for pairs that make a ten or a hundred. Example: 18 + 39 + 32. Notice 18 + 32 = 50 (a friendly number!). Reorder: (18 + 32) + 39 = 50 + 39 = 89.",
      "cpa_phase": "abstract",
      "visual_type": "highlight",
      "visual_data": {
        "numbers": [
          18,
          39,
          32
        ],
        "friendly_pair": [
          18,
          32
        ],
        "pair_sum": 50,
        "total": 89
      },
      "verification": "Go Math p.23 Q4 — 18+39+32"
    },
    {
      "id": "LEARN_07",
      "title": "Four Addends",
      "content": "You can use properties with four or more addends too! Example: 33 + 71 + 56 + 29. Look for pairs: 71 + 29 = 100! Reorder: (71 + 29) + (33 + 56) = 100 + 89 = 189.",
      "cpa_phase": "abstract",
      "visual_type": "step_by_step",
      "visual_data": {
        "steps": [
          "33+71+56+29",
          "Pair: 71+29=100",
          "Pair: 33+56=89",
          "100+89=189"
        ]
      },
      "verification": "Go Math p.23 Q7 — four addends"
    },
    {
      "id": "LEARN_08",
      "title": "Key Idea Summary",
      "content": "Three properties help you add: Commutative (change order), Associative (change grouping), Identity (add 0). Strategy: look for pairs that make 10, 50, or 100, then reorder and regroup to add mentally.",
      "cpa_phase": "abstract",
      "visual_type": "summary_card",
      "visual_data": {},
      "verification": "Go Math pp.21-24 lesson summary"
    }
  ],
