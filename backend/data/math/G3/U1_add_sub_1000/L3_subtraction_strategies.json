  "learn": [
    {
      "id": "u1L3_learn_01",
      "title": "Subtracting Without Regrouping",
      "type": "concept",
      "cpa_phase": "concrete",
      "content": "When the top digit in each column is bigger than the bottom, just subtract each column: ones, tens, hundreds.",
      "visual": {
        "tool": "base10_blocks",
        "config": {"start": 586, "max": 999}
      },
      "tts": "When we subtract and the top digit in each column is larger than the bottom, we simply subtract each column: ones, tens, then hundreds.",
      "interaction": "none"
    },
    {
      "id": "u1L3_learn_02",
      "title": "What is Regrouping in Subtraction?",
      "type": "concept",
      "cpa_phase": "concrete",
      "content": "When the top digit is smaller than the bottom, we borrow from the next column. 1 ten becomes 10 ones. 1 hundred becomes 10 tens.",
      "visual": "Animation: 1 rod breaks into 10 unit cubes",
      "tts": "When the top digit is smaller than the bottom, we borrow. One ten becomes ten ones. One hundred becomes ten tens.",
      "interaction": "none"
    },
