  "learn": [
    {
      "id": "LEARN_01",
      "type": "concept_card",
      "title": "What Does 'Combine Place Values' Mean?",
      "content": "Instead of regrouping one place at a time, you can COMBINE place values before subtracting. Example: 700 = 7 hundreds. You can think of it as 6 hundreds + 10 tens, or 6 hundreds + 9 tens + 10 ones. Then subtract!",
      "visual_type": "place_value_chart",
      "cpa_phase": "concrete"
    },
    {
      "id": "LEARN_02",
      "type": "concept_card",
      "title": "Example: 700 − 326",
      "content": "Step 1: 700 = 6 hundreds + 9 tens + 10 ones (combine!). Step 2: Ones: 10−6=4. Step 3: Tens: 9−2=7. Step 4: Hundreds: 6−3=3. Answer: 374.",
      "visual_type": "step_by_step",
      "cpa_phase": "pictorial",
      "example": {
        "problem": "700−326",
        "combined": "6h 9t 10o",
        "answer": 374
      }
    },
    {
      "id": "LEARN_03",
      "type": "concept_card",
      "title": "Why Combine?",
      "content": "When you have zeros in the middle (like 700, 508, 900), combining makes it easier because you do all the regrouping in ONE step instead of going back and forth.",
      "visual_type": "comparison_table",
      "cpa_phase": "abstract"
    },
    {
      "id": "LEARN_04",
      "type": "concept_card",
      "title": "Example: 476 − 269",
      "content": "Ones: 6−9? Can't! Regroup: 476 = 4h 6t 16o. 16−9=7. Tens: 6−6=0. Hundreds: 4−2=2. Answer: 207.",
      "visual_type": "step_by_step",
      "cpa_phase": "pictorial"
    },
    {
      "id": "LEARN_05",
      "type": "concept_card",
      "title": "Example: 900 − 158",
      "content": "900 = 8 hundreds + 9 tens + 10 ones. Ones: 10−8=2. Tens: 9−5=4. Hundreds: 8−1=7. Answer: 742.",
      "visual_type": "step_by_step",
      "cpa_phase": "pictorial",
      "example": {
        "problem": "900−158",
        "combined": "8h 9t 10o",
        "answer": 742
      }
    },
    {
      "id": "LEARN_06",
      "type": "concept_card",
      "title": "Estimate First!",
      "content": "Always estimate before solving. 476−269: estimate 500−300=200. Your answer (207) is close. 700−326: estimate 700−300=400. Your answer (374) is close.",
      "visual_type": "comparison_table",
      "cpa_phase": "abstract"
    },
    {
      "id": "LEARN_07",
      "type": "concept_card",
      "title": "Check by Adding",
      "content": "After subtracting, add your answer to the smaller number. 374+326=700 ✓. 207+269=476 ✓. If they match, your subtraction is correct!",
      "visual_type": "step_by_step",
      "cpa_phase": "abstract"
    },
    {
      "id": "LEARN_08",
      "type": "concept_card",
      "title": "Combining vs. Regular Regrouping",
      "content": "Both methods give the same answer! Combining is just a shortcut for numbers with zeros. Use whichever method feels easier to you.",
      "visual_type": "comparison_table",
      "cpa_phase": "abstract"
    }
  ],
