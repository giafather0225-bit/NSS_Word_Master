  "learn": [
    {
      "id": "LN_01",
      "type": "concept_card",
      "title": "What Is the Order of Operations?",
      "content": "When an expression has more than one operation, you need rules to know which to do first. Without rules, different people get different answers! The order of operations gives everyone the same result.",
      "cpa_phase": "concrete",
      "visual_type": "rules_list",
      "visual_data": {
        "steps": [
          "1. Parentheses — solve what is inside ( ) first",
          "2. Multiply and Divide — left to right",
          "3. Add and Subtract — left to right"
        ]
      }
    },
    {
      "id": "LN_02",
      "type": "concept_card",
      "title": "Multiply Before You Add",
      "content": "Look at 3 + 4 × 2. If you add first: 3 + 4 = 7, then 7 × 2 = 14 (wrong!). If you multiply first: 4 × 2 = 8, then 3 + 8 = 11 (correct!). Always multiply or divide before you add or subtract.",
      "cpa_phase": "concrete",
      "visual_type": "two_path_diagram",
      "visual_data": {
        "expression": "3 + 4 × 2",
        "wrong_path": {
          "label": "Wrong: add first",
          "steps": [
            "3 + 4 = 7",
            "7 × 2 = 14"
          ]
        },
        "correct_path": {
          "label": "Correct: multiply first",
          "steps": [
            "4 × 2 = 8",
            "3 + 8 = 11"
          ]
        }
      }
    },
    {
      "id": "LN_03",
      "type": "concept_card",
      "title": "Parentheses Change the Answer",
      "content": "Adding parentheses can change the result completely. Compare: 2 + 3 × 4 = 2 + 12 = 14 (no parentheses — multiply first). But (2 + 3) × 4 = 5 × 4 = 20 (parentheses first — different answer!).",
      "cpa_phase": "pictorial",
      "visual_type": "comparison_table",
      "visual_data": {
        "rows": [
          {
            "expression": "2 + 3 × 4",
            "step1": "3 × 4 = 12",
            "step2": "2 + 12 = 14",
            "result": "14"
          },
          {
            "expression": "(2 + 3) × 4",
            "step1": "2 + 3 = 5",
            "step2": "5 × 4 = 20",
            "result": "20"
          }
        ]
      }
    },
    {
      "id": "LN_04",
      "type": "concept_card",
      "title": "Division Before Subtraction",
      "content": "Division also comes before addition and subtraction. In 20 − 15 ÷ 3: divide first → 15 ÷ 3 = 5. Then subtract → 20 − 5 = 15. If you subtract first you get the wrong answer.",
      "cpa_phase": "pictorial",
      "visual_type": "step_diagram",
      "visual_data": {
        "expression": "20 − 15 ÷ 3",
        "steps": [
          {
            "step": "Step 1 — Divide",
            "work": "15 ÷ 3 = 5"
          },
          {
            "step": "Step 2 — Subtract",
            "work": "20 − 5 = 15"
          }
        ],
        "result": "15"
      }
    },
    {
      "id": "LN_05",
      "type": "concept_card",
      "title": "Label Each Step",
      "content": "When an expression is complex, label every step: Step 1 — Parentheses, Step 2 — × or ÷, Step 3 — + or −. Example: 2 + 3 × (8 − 2). Step 1: 8 − 2 = 6. Step 2: 3 × 6 = 18. Step 3: 2 + 18 = 20.",
      "cpa_phase": "abstract",
      "visual_type": "none"
    }
  ],
