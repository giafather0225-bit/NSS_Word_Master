  "learn": [
    {
      "type": "concept_card",
      "title": "Sharing Into 4 Equal Groups",
      "content": "When you divide by 4, you share a total equally among 4 groups. Example: 24 counters shared into 4 groups → each group gets 6. So 24 ÷ 4 = 6.",
      "id": "LN_01",
      "cpa_phase": "concrete",
      "visual_type": "manipulative",
      "visual_data": {
        "tool": "counter_groups",
        "config": {
          "total": 24,
          "groups": 4,
          "per_group": 6
        }
      }
    },
    {
      "type": "concept_card",
      "title": "Halve Twice Strategy",
      "content": "Dividing by 4 is the same as halving twice. Try with 20:\nStep 1: 20 ÷ 2 = 10 (first half)\nStep 2: 10 ÷ 2 = 5 (half again)\nResult: 20 ÷ 4 = 5.\nThis works because 4 = 2 × 2.",
      "id": "LN_02",
      "cpa_phase": "concrete",
      "visual_type": "diagram",
      "visual_data": {
        "tool": "halve_twice",
        "config": {
          "start": 20,
          "step1": 10,
          "step2": 5
        }
      }
    },
    {
      "type": "concept_card",
      "title": "Relate to ×4 Multiplication",
      "content": "Draw 4 rows of 9 dots — that is a 4×9 array showing 36 total. Reading it as division: 36 dots in 4 rows means 36 ÷ 4 = 9 dots per row. Every ×4 fact gives a ÷4 fact.",
      "id": "LN_03",
      "cpa_phase": "pictorial",
      "visual_type": "diagram",
      "visual_data": {
        "tool": "array_grid",
        "config": {
          "rows": 4,
          "cols": 9
        }
      }
    },
    {
      "type": "concept_card",
      "title": "Number Line: Backward Jumps of 4",
      "content": "To find 36 ÷ 4, start at 36 on a number line and hop backward by 4 each time: 36 → 32 → 28 → 24 → 20 → 16 → 12 → 8 → 4 → 0. Count the hops: 9 hops. So 36 ÷ 4 = 9.",
      "id": "LN_04",
      "cpa_phase": "pictorial",
      "visual_type": "number_line",
      "visual_data": {
        "tool": "number_line",
        "config": {
          "start": 36,
          "end": 0,
          "jump": -4,
          "label": "36 ÷ 4 = 9 hops"
        }
      }
    },
    {
      "type": "concept_card",
      "title": "The ÷4 Pattern: Reverse the ×4 Fact",
      "content": "Every ×4 fact gives you a ÷4 fact:\n4×1=4 → 4÷4=1\n4×2=8 → 8÷4=2\n4×3=12 → 12÷4=3\n4×4=16 → 16÷4=4\n4×5=20 → 20÷4=5\n4×6=24 → 24÷4=6\n4×7=28 → 28÷4=7\n4×8=32 → 32÷4=8\n4×9=36 → 36÷4=9\n4×10=40 → 40÷4=10\nStrategy: think '4 × ? = dividend' to find the quotient.",
      "id": "LN_05",
      "cpa_phase": "abstract",
      "visual_type": "table",
      "visual_data": {
        "tool": "fact_table",
        "config": {
          "divisor": 4,
          "range": [
            1,
            10
          ]
        }
      }
    }
  ],
