    {
      "id": "LN_05",
      "type": "concept_card",
      "title": "The Drop-the-Zero Rule",
      "content": "For any multiple of 10: n×10 ÷ 10 = n. Just remove the trailing zero. 10÷10=1, 20÷10=2, 30÷10=3, ... 90÷10=9, 100÷10=10. This works because 10 groups of n = 10n, so 10n÷10 = n.",
      "cpa_phase": "abstract",
      "visual_type": "formula",
      "visual_data": {
        "formula": "(n × 10) ÷ 10 = n",
        "examples": ["30 ÷ 10 = 3", "70 ÷ 10 = 7", "100 ÷ 10 = 10"]
      }
    }
