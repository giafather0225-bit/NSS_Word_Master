  "learn": [
    {
      "id": "LN_01",
      "type": "concept_card",
      "title": "Dividing by 2",
      "content": "Dividing by 2 is the same as finding half. 10 ÷ 2 = 5 because half of 10 is 5. You split one group into exactly 2 equal parts.",
      "cpa_phase": "concrete",
      "visual_type": "manipulative",
      "visual_data": {
        "tool": "counter_groups",
        "config": {
          "total": 10,
          "groups": 2,
          "label": "10 ÷ 2 = 5"
        }
      }
    },
    {
      "id": "LN_02",
      "type": "concept_card",
      "title": "Use Doubles",
      "content": "If you know 2 × 8 = 16, then 16 ÷ 2 = 8. Doubles facts help you divide by 2 quickly. Think: 2 × ? = 16 → ? = 8.",
      "cpa_phase": "concrete",
      "visual_type": "manipulative",
      "visual_data": {
        "tool": "array_grid",
        "config": {
          "rows": 2,
          "cols": 8,
          "label": "2 × 8 = 16  →  16 ÷ 2 = 8"
        }
      }
    },
    {
      "id": "LN_03",
      "type": "concept_card",
      "title": "Model It with Two Groups",
      "content": "To find 14 ÷ 2: draw 2 circles. Deal 14 counters one by one, alternating circles. Each circle gets 7. So 14 ÷ 2 = 7.",
      "cpa_phase": "pictorial",
      "visual_type": "diagram",
      "visual_data": {
        "tool": "counter_groups",
        "config": {
          "total": 14,
          "groups": 2,
          "label": "14 ÷ 2 = 7"
        }
      }
    },
    {
      "id": "LN_04",
      "type": "concept_card",
      "title": "Halving on a Number Line",
      "content": "On a number line, 12 ÷ 2 = 6 means: start at 12, make jumps of 2 going back. Count: 12→10→8→6→4→2→0 — that's 6 jumps. So 12 ÷ 2 = 6.",
      "cpa_phase": "pictorial",
      "visual_type": "number_line",
      "visual_data": {
        "start": 12,
        "jump": 2,
        "end": 0,
        "count": 6,
        "label": "12 ÷ 2 = 6 (6 jumps of 2)"
      }
    },
    {
      "id": "LN_05",
      "type": "concept_card",
      "title": "The Halving Rule",
      "content": "Dividing by 2 always gives you half the number. Half of 18 = 9, so 18 ÷ 2 = 9. You can also think of it as: 2 × quotient = dividend. This works for ALL even numbers.",
      "cpa_phase": "abstract",
      "visual_type": "formula",
      "visual_data": {
        "formula": "n ÷ 2 = half of n",
        "examples": [
          "18 ÷ 2 = 9",
          "16 ÷ 2 = 8",
          "14 ÷ 2 = 7"
        ]
      }
    }
  ],
