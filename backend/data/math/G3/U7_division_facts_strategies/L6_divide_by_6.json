  "learn": [
    {
      "type": "concept_card",
      "title": "Sharing Into 6 Equal Groups",
      "content": "When you divide by 6, you share a total equally among 6 groups. Example: 36 counters shared into 6 groups → each group gets 6. So 36 ÷ 6 = 6.",
      "id": "LN_01",
      "cpa_phase": "concrete",
      "visual_type": "manipulative",
      "visual_data": {
        "tool": "counter_groups",
        "config": {
          "total": 36,
          "groups": 6,
          "per_group": 6
        }
      }
    },
    {
      "type": "concept_card",
      "title": "Array: 6 Rows",
      "content": "A 6×8 array has 48 tiles arranged in 6 rows of 8. Reading it as division: 48 tiles in 6 rows means 48 ÷ 6 = 8 tiles per row. The ×6 fact 6×8=48 gives the ÷6 fact 48÷6=8.",
      "id": "LN_02",
      "cpa_phase": "concrete",
      "visual_type": "manipulative",
      "visual_data": {
        "tool": "array_grid",
        "config": {
          "rows": 6,
          "cols": 8
        }
      }
    },
    {
      "type": "concept_card",
      "title": "Break ÷6 Into ÷2 Then ÷3",
      "content": "Since 6 = 2 × 3, dividing by 6 is the same as dividing by 2 and then by 3. Example: 24 ÷ 6\nStep 1: 24 ÷ 2 = 12\nStep 2: 12 ÷ 3 = 4\nResult: 24 ÷ 6 = 4. Check: 6 × 4 = 24 ✓",
      "id": "LN_03",
      "cpa_phase": "pictorial",
      "visual_type": "diagram",
      "visual_data": {
        "tool": "two_step_divide",
        "config": {
          "start": 24,
          "step1_divisor": 2,
          "step1_result": 12,
          "step2_divisor": 3,
          "step2_result": 4
        }
      }
    },
    {
      "type": "concept_card",
      "title": "Number Line: Backward Jumps of 6",
      "content": "To find 48 ÷ 6, start at 48 on a number line and hop backward by 6 each time: 48 → 42 → 36 → 30 → 24 → 18 → 12 → 6 → 0. Count the hops: 8 hops. So 48 ÷ 6 = 8.",
      "id": "LN_04",
      "cpa_phase": "pictorial",
      "visual_type": "number_line",
      "visual_data": {
        "tool": "number_line",
        "config": {
          "start": 48,
          "end": 0,
          "jump": -6,
          "label": "48 ÷ 6 = 8 hops"
        }
      }
    },
    {
      "type": "concept_card",
      "title": "The ÷6 Pattern: Reverse the ×6 Fact",
      "content": "Every ×6 fact gives you a ÷6 fact:\n6×1=6 → 6÷6=1\n6×2=12 → 12÷6=2\n6×3=18 → 18÷6=3\n6×4=24 → 24÷6=4\n6×5=30 → 30÷6=5\n6×6=36 → 36÷6=6\n6×7=42 → 42÷6=7\n6×8=48 → 48÷6=8\n6×9=54 → 54÷6=9\n6×10=60 → 60÷6=10\nStrategy: think '6 × ? = dividend' to find the quotient.",
      "id": "LN_05",
      "cpa_phase": "abstract",
      "visual_type": "table",
      "visual_data": {
        "tool": "fact_table",
        "config": {
          "divisor": 6,
          "range": [
            1,
            10
          ]
        }
      }
    }
  ],
