    {
      "id": "LN_01",
      "section": "learn",
      "difficulty": 0,
      "type": "concept_card",
      "title": "What is a Bar Graph?",
      "content": "A bar graph uses bars to show data. The length or height of each bar shows the value. One axis shows categories, the other shows numbers (the scale).",
      "cpa_phase": "concrete",
      "visual_type": "none"
    },
    {
      "id": "LN_02",
      "section": "learn",
      "difficulty": 0,
      "type": "concept_card",
      "title": "Reading the Scale",
      "content": "The scale is the set of numbers along one axis. It can count by 1s, 2s, 5s, 10s, etc. To read a bar's value, look at where the bar ends and match it to the scale.",
      "cpa_phase": "concrete",
      "visual_type": "none"
    },
    {
      "id": "LN_03",
      "section": "learn",
      "difficulty": 0,
      "type": "concept_card",
      "title": "Comparing Bars",
      "content": "The tallest (or longest) bar represents the most. The shortest bar represents the least. To find 'how many more' or 'how many fewer,' subtract the two values.",
      "cpa_phase": "pictorial",
      "visual_type": "none"
    },
