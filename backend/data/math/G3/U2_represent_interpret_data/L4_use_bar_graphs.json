  "items": [
    {
      "id": "PT_01",
      "section": "pretest",
      "difficulty": 1,
      "question": "A bar graph has a scale of 0, 2, 4, 6, 8. The bar for 'Soccer' ends at 6. How many students chose Soccer?",
      "choices": [
        "A) 3",
        "B) 4",
        "C) 6",
        "D) 8"
      ],
      "explanation": "The bar ends at 6, so 6 students.",
      "correct_answer": "C",
      "type": "mc"
    },
    {
      "id": "PT_02",
      "section": "pretest",
