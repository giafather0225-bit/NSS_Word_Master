{
  "lesson_id": "L6_solve_problems_using_data",
  "title": "Solve Problems Using Data",
  "grade": "G3",
  "unit": "U2_represent_interpret_data",
  "ccss": ["3.MD.B.3"],
  "go_math_ref": { "chapter": 2, "lesson": "2.6", "pages": "85-88" },
  "essential_question": "How can you solve problems using data shown in bar graphs and picture graphs?",
  "key_vocabulary": ["compare", "how many more", "how many fewer", "combined", "total", "not"],
  "strategies": ["Add to find totals or combined amounts", "Subtract to find differences", "Use 'did not choose' = total minus that category"],
  "items": [
    {
      "id": "PT_01", "section": "pretest", "difficulty": 1,
      "question": "Bar graph: Pizza 11, Chicken 4, Hot Dog 7, Grilled Cheese 2. How many more students chose Pizza than Grilled Cheese?",
      "data_table": { "title": "Favorite Hot Lunch", "type": "bar_graph", "categories": ["Pizza","Chicken","Hot Dog","Grilled Cheese"], "values": [11,4,7,2], "scale": 1, "unit": "students", "axis_label": {"x":"Food","y":"Students"} },
      "choices": ["A. 7","B. 9","C. 11","D. 13"], "answer": "B",
      "explanation": "11 − 2 = 9."
    },
    {
      "id": "PT_02", "section": "pretest", "difficulty": 1,
      "question": "Same lunch graph. How many students chose Chicken or Hot Dog?",
      "data_table": { "title": "Favorite Hot Lunch", "type": "bar_graph", "categories": ["Pizza","Chicken","Hot Dog","Grilled Cheese"], "values": [11,4,7,2], "scale": 1, "unit": "students", "axis_label": {"x":"Food","y":"Students"} },
      "choices": ["A. 7","B. 9","C. 11","D. 13"], "answer": "C",
      "explanation": "4 + 7 = 11."
    },
    {
      "id": "PT_03", "section": "pretest", "difficulty": 2,
      "question": "Bar graph: Walk 10, Bus 12, Car 6, Bike 4. How many more students walk than ride a bike?",
      "data_table": { "title": "Ways to School", "type": "bar_graph", "categories": ["Walk","Bus","Car","Bike"], "values": [10,12,6,4], "scale": 2, "unit": "students", "axis_label": {"x":"Way","y":"Students"} },
      "choices": ["A. 4","B. 6","C. 8","D. 10"], "answer": "B",
      "explanation": "10 − 4 = 6."
    },
    {
      "id": "PT_04", "section": "pretest", "difficulty": 2,
      "question": "Same school graph. How many students walk and ride a bike combined?",
      "data_table": { "title": "Ways to School", "type": "bar_graph", "categories": ["Walk","Bus","Car","Bike"], "values": [10,12,6,4], "scale": 2, "unit": "students", "axis_label": {"x":"Way","y":"Students"} },
      "choices": ["A. 10","B. 12","C. 14","D. 16"], "answer": "C",
      "explanation": "10 + 4 = 14."
    },
    {
      "id": "PT_05", "section": "pretest", "difficulty": 2,
      "question": "Bar graph: Bench Repair 4, Food Drive 14, Book Fair 10, Playground 6. How many votes were there in all?",
      "data_table": { "title": "School Project Votes", "type": "bar_graph", "categories": ["Bench Repair","Food Drive","Book Fair","Playground"], "values": [4,14,10,6], "scale": 2, "unit": "votes", "axis_label": {"x":"Project","y":"Votes"} },
      "choices": ["A. 14","B. 24","C. 30","D. 34"], "answer": "D",
      "explanation": "4+14+10+6 = 34."
    },
    {
      "id": "LN_01", "section": "learn", "difficulty": 0,
      "type": "concept_card",
      "title": "Solving 'How Many More / Fewer'",
      "content": "Find the values for the two categories being compared. Subtract the smaller from the larger. The result tells you 'how many more' or 'how many fewer.'"
    },
    {
      "id": "LN_02", "section": "learn", "difficulty": 0,
      "type": "concept_card",
      "title": "Solving 'How Many in All' or 'Combined'",
      "content": "Add the values of the categories mentioned. If the question says 'in all,' add every category. If it says 'combined' for specific categories, add only those."
    },
    {
      "id": "LN_03", "section": "learn", "difficulty": 0,
      "type": "concept_card",
      "title": "Solving 'Did Not Choose'",
      "content": "First find the total (add all categories). Then subtract the category mentioned. Total − category = number who did NOT choose it."
    },
    {
      "id": "TRY_01", "section": "try", "difficulty": 1,
      "question": "Bar graph: Art 8, Music 12, PE 10. How many students did NOT choose Music?",
      "data_table": { "title": "Favorite Special", "type": "bar_graph", "categories": ["Art","Music","PE"], "values": [8,12,10], "scale": 2, "unit": "students", "axis_label": {"x":"Subject","y":"Students"} },
      "choices": ["A. 8","B. 12","C. 18","D. 30"], "answer": "C",
      "explanation": "Total: 8+12+10=30. Not Music: 30−12=18."
    },
    {
      "id": "TRY_02", "section": "try", "difficulty": 2,
      "question": "Bar graph: Mon 6, Tue 10, Wed 4, Thu 8. How many more books were checked out on Tuesday than Wednesday?",
      "data_table": { "title": "Library Checkouts", "type": "bar_graph", "categories": ["Mon","Tue","Wed","Thu"], "values": [6,10,4,8], "scale": 2, "unit": "books", "axis_label": {"x":"Day","y":"Books"} },
      "choices": ["A. 2","B. 4","C. 6","D. 8"], "answer": "C",
      "explanation": "10 − 4 = 6."
    },
    {
      "id": "TRY_03", "section": "try", "difficulty": 2,
      "question": "Bar graph: Pizza 11, Chicken 4, Hot Dog 7, Grilled Cheese 2. How many students did NOT choose Chicken?",
      "data_table": { "title": "Favorite Hot Lunch", "type": "bar_graph", "categories": ["Pizza","Chicken","Hot Dog","Grilled Cheese"], "values": [11,4,7,2], "scale": 1, "unit": "students", "axis_label": {"x":"Food","y":"Students"} },
      "choices": ["A. 4","B. 13","C. 18","D. 20"], "answer": "D",
      "explanation": "Total: 11+4+7+2=24. Not Chicken: 24−4=20."
    },
    {
      "id": "R1_01", "section": "practice_r1", "difficulty": 1,
      "question": "Bar graph: Cats 9, Dogs 15, Fish 6. How many more students chose Dogs than Fish?",
      "data_table": { "title": "Pet Survey", "type": "bar_graph", "categories": ["Cats","Dogs","Fish"], "values": [9,15,6], "scale": 3, "unit": "students", "axis_label": {"x":"Pet","y":"Students"} },
      "choices": ["A. 6","B. 9","C. 12","D. 15"], "answer": "B",
      "explanation": "15 − 6 = 9."
    },
    {
      "id": "R1_02", "section": "practice_r1", "difficulty": 1,
      "question": "Bar graph: Red 10, Blue 8, Yellow 4, Green 6. How many students chose Red or Yellow?",
      "data_table": { "title": "Favorite Color", "type": "bar_graph", "categories": ["Red","Blue","Yellow","Green"], "values": [10,8,4,6], "scale": 2, "unit": "students", "axis_label": {"x":"Color","y":"Students"} },
      "choices": ["A. 10","B. 12","C. 14","D. 18"], "answer": "C",
      "explanation": "10 + 4 = 14."
    },
    {
      "id": "R1_03", "section": "practice_r1", "difficulty": 2,
      "question": "Bar graph: Grilled Cheese 2, Hot Dog 7. How many fewer students chose Grilled Cheese than Hot Dog?",
      "choices": ["A. 2","B. 3","C. 5","D. 7"], "answer": "C",
      "explanation": "7 − 2 = 5."
    },
    {
      "id": "R1_04", "section": "practice_r1", "difficulty": 2,
      "question": "Bar graph: Soccer 14, Basketball 8, Tennis 6, Swimming 12. How many students did NOT choose Soccer?",
      "data_table": { "title": "Sports Vote", "type": "bar_graph", "categories": ["Soccer","Basketball","Tennis","Swimming"], "values": [14,8,6,12], "scale": 2, "unit": "students", "axis_label": {"x":"Sport","y":"Students"} },
      "choices": ["A. 14","B. 20","C. 26","D. 40"], "answer": "C",
      "explanation": "Total: 14+8+6+12=40. Not Soccer: 40−14=26."
    },
    {
      "id": "R1_05", "section": "practice_r1", "difficulty": 2,
      "question": "Bar graph: Bench Repair 4, Food Drive 14, Book Fair 10, Playground 6. How many fewer votes for Bench Repair than Food Drive?",
      "data_table": { "title": "School Project", "type": "bar_graph", "categories": ["Bench Repair","Food Drive","Book Fair","Playground"], "values": [4,14,10,6], "scale": 2, "unit": "votes", "axis_label": {"x":"Project","y":"Votes"} },
      "choices": ["A. 6","B. 8","C. 10","D. 14"], "answer": "C",
      "explanation": "14 − 4 = 10."
    },
    {
      "id": "R2_01", "section": "practice_r2", "difficulty": 2,
      "question": "Bar graph: Walk 10, Bus 12, Car 6, Bike 4. What if 5 more students respond that they bike. Would more students Walk or Bike to school?",
      "data_table": { "title": "Ways to School", "type": "bar_graph", "categories": ["Walk","Bus","Car","Bike"], "values": [10,12,6,4], "scale": 2, "unit": "students", "axis_label": {"x":"Way","y":"Students"} },
      "choices": ["A. Walk, because 10 > 9","B. Bike, because 9 > 10","C. Equal, both 10","D. Walk, because 10 > 4"], "answer": "A",
      "explanation": "Bike becomes 4+5=9. Walk = 10. 10 > 9, so more Walk."
    },
    {
      "id": "R2_02", "section": "practice_r2", "difficulty": 3,
      "question": "Sue spent $18 on a shirt, $39 on a jacket, and $12 on a hat. How much did she spend in all?",
      "choices": ["A. $79","B. $69","C. $57","D. $51"], "answer": "B",
      "explanation": "18+39+12 = 69."
    },
    {
      "id": "R2_03", "section": "practice_r2", "difficulty": 3,
      "question": "219 adults and 174 children are at a ballet. How many people in all?",
      "choices": ["A. 45","B. 293","C. 383","D. 393"], "answer": "D",
      "explanation": "219+174 = 393."
    },
    {
      "id": "R2_04", "section": "practice_r2", "difficulty": 3,
      "question": "Bar graph: Pizza 11, Chicken 4, Hot Dog 7, Grilled Cheese 2. The cafeteria can make 25 lunches. How many lunches are left over?",
      "data_table": { "title": "Lunch Orders", "type": "bar_graph", "categories": ["Pizza","Chicken","Hot Dog","Grilled Cheese"], "values": [11,4,7,2], "scale": 1, "unit": "lunches", "axis_label": {"x":"Food","y":"Orders"} },
      "choices": ["A. 0","B. 1","C. 2","D. 3"], "answer": "B",
      "explanation": "Total orders: 11+4+7+2=24. 25−24=1 lunch left."
    },
    {
      "id": "R3_01", "section": "practice_r3", "difficulty": 3,
      "question": "Bar graph: Class A = 18 books, Class B = 24 books, Class C = 12 books. Class A and Class C want to beat Class B's total together. How many more books do they need?",
      "data_table": { "title": "Read-a-thon", "type": "bar_graph", "categories": ["Class A","Class B","Class C"], "values": [18,24,12], "scale": 2, "unit": "books", "axis_label": {"x":"Class","y":"Books"} },
      "choices": ["A. None, they already beat it","B. 4 more","C. 6 more","D. 12 more"], "answer": "A",
      "explanation": "A+C = 18+12 = 30. B = 24. 30 > 24, they already beat it."
    },
    {
      "id": "R3_02", "section": "practice_r3", "difficulty": 3,
      "question": "75 basketball cards rounded to the nearest ten is?",
      "choices": ["A. 60","B. 70","C. 80","D. 90"], "answer": "C",
      "explanation": "75 → 5 in ones place = round up → 80."
    },
    {
      "id": "R3_03", "section": "practice_r3", "difficulty": 3,
      "question": "Bar graph: Apples 20, Oranges 15, Bananas 10, Grapes 5. A store needs 60 fruits total. How many more fruits are needed?",
      "data_table": { "title": "Fruit Inventory", "type": "bar_graph", "categories": ["Apples","Oranges","Bananas","Grapes"], "values": [20,15,10,5], "scale": 5, "unit": "fruits", "axis_label": {"x":"Fruit","y":"Count"} },
      "choices": ["A. 5","B. 10","C. 15","D. 20"], "answer": "B",
      "explanation": "Total: 20+15+10+5=50. Need: 60−50=10."
    }
  ]
}
