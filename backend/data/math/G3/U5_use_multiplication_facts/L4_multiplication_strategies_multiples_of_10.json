  "learn": [
    {
      "id": "LN_01",
      "type": "concept_card",
      "title": "Number Line Strategy",
      "content": "To find 2 × 40, start at 0 and make 2 jumps of 40 on a number line: 0 → 40 → 80. So 2 × 40 = 80.",
      "cpa_phase": "concrete",
      "visual_type": "manipulative",
      "visual_data": {
        "tool": "array_grid",
        "config": {
          "rows": 2,
          "cols": 4
        }
      }
    },
    {
      "id": "LN_02",
      "type": "concept_card",
      "title": "Place Value Strategy",
      "content": "Rewrite the multiple of 10 in tens. 5 × 70 = 5 × 7 tens = 35 tens = 350. Use the basic fact (5 × 7 = 35) then think in tens.",
      "cpa_phase": "concrete",
      "visual_type": "manipulative",
      "visual_data": {
        "tool": "array_grid",
        "config": {
          "rows": 5,
          "cols": 7
        }
      }
    },
    {
      "id": "LN_03",
      "type": "concept_card",
      "title": "The Zero Trick",
      "content": "Multiply the non-zero digits: 6 × 4 = 24. Then put back the zero: 6 × 40 = 240. This works because 40 = 4 × 10.",
      "cpa_phase": "pictorial",
      "visual_type": "manipulative",
      "visual_data": {
        "tool": "array_grid",
        "config": {
          "rows": 6,
          "cols": 4
        }
      }
    },
    {
      "id": "LN_04",
      "type": "concept_card",
      "title": "Number Line for Bigger Facts",
      "content": "You can use a number line for any multiple of 10. For 4 × 30: start at 0 and jump 30 four times: 0 → 30 → 60 → 90 → 120. Count the jumps and you land on 120. So 4 × 30 = 120.",
      "cpa_phase": "pictorial",
      "visual_type": "number_line",
      "visual_data": {
        "tool": "number_line",
        "config": {
          "start": 0,
          "end": 120,
          "jump_size": 30,
          "num_jumps": 4
        }
      }
    },
    {
      "id": "LN_05",
      "type": "concept_card",
      "title": "The Rule Always Works",
      "content": "For any multiplication with a multiple of 10: A × (B × 10) = (A × B) × 10. Examples: 5 × 40 = (5 × 4) × 10 = 20 × 10 = 200. 9 × 60 = (9 × 6) × 10 = 54 × 10 = 540. Step 1: find the basic fact. Step 2: multiply by 10 (add a zero).",
      "cpa_phase": "abstract",
      "visual_type": "equation",
      "visual_data": {
        "tool": "equation_display",
        "config": {
          "equations": [
            "A × (B × 10) = (A × B) × 10",
            "5 × 40 = (5 × 4) × 10 = 200",
            "9 × 60 = (9 × 6) × 10 = 540"
          ]
        }
      }
    }
  ],
