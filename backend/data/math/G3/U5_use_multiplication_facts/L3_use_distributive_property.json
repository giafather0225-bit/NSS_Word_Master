  "learn": [
    {
      "id": "LN_01",
      "type": "concept_card",
      "title": "The Distributive Property",
      "content": "You can break apart one factor to make multiplication easier. Example: 6 × 30 = 6 × (10 + 10 + 10) = 60 + 60 + 60 = 180. Breaking the factor into smaller parts gives the same product.",
      "cpa_phase": "concrete",
      "visual_type": "manipulative",
      "visual_data": {
        "tool": "array_grid",
        "config": {
          "rows": 6,
          "cols": 3
        }
      }
    },
    {
      "id": "LN_02",
      "type": "concept_card",
      "title": "Using Place Value",
      "content": "Think of 30 as 3 tens. So 6 × 30 = 6 × 3 tens = 18 tens = 180. The shortcut: multiply the one-digit factor by the non-zero digit, then attach a zero. 6 × 3 = 18 → 6 × 30 = 180.",
      "cpa_phase": "concrete",
      "visual_type": "none"
    },
    {
      "id": "LN_03",
      "type": "concept_card",
      "title": "Solving Word Problems",
      "content": "Identify the two factors, then use place value. Example: 8 buses × 40 students = 8 × 4 tens = 32 tens = 320 students. Read the problem, write the equation, apply the strategy.",
      "cpa_phase": "pictorial",
      "visual_type": "none"
    },
    {
      "id": "LN_04",
      "type": "concept_card",
      "title": "Break Into Any Two Parts",
      "content": "You can split a factor into any two addends: 6 × 7 = 6 × (3 + 4) = 18 + 24 = 42. Or split a multiple of 10: 7 × 30 = 7 × (20 + 10) = 140 + 70 = 210. Any split works as long as the parts add up to the original factor.",
      "cpa_phase": "abstract",
      "visual_type": "none"
    },
    {
      "id": "LN_05",
      "type": "concept_card",
      "title": "Why It Always Works",
      "content": "The rule is: a × (b + c) = (a × b) + (a × c). Example: 5 × (20 + 30) = (5 × 20) + (5 × 30) = 100 + 150 = 250. This is the same as 5 × 50 = 250. The Distributive Property always gives the same answer.",
      "cpa_phase": "abstract",
      "visual_type": "none"
    }
  ],
