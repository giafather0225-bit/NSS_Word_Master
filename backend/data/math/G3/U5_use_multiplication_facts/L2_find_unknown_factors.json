  "learn": [
    {
      "id": "LN_01",
      "type": "concept_card",
      "title": "What Is an Unknown Factor?",
      "content": "In the equation n × 3 = 12, the unknown factor is n. You need to find what number times 3 equals 12. The letter (n, m, x, etc.) is a placeholder for the missing factor.",
      "cpa_phase": "concrete",
      "visual_type": "none"
    },
    {
      "id": "LN_02",
      "type": "concept_card",
      "title": "Strategy: Skip Count to Find It",
      "content": "To find n in n × 5 = 30, skip count by 5s: 5, 10, 15, 20, 25, 30 — that is 6 jumps. So n = 6. Or use a known fact: 6 × 5 = 30.",
      "cpa_phase": "concrete",
      "visual_type": "manipulative",
      "visual_data": {
        "tool": "array_grid",
        "config": {
          "rows": 6,
          "cols": 5
        }
      }
    },
    {
      "id": "LN_03",
      "type": "concept_card",
      "title": "Strategy: Use an Array",
      "content": "For 3 × □ = 24, draw 3 rows. Keep adding columns until you reach 24 dots total — you will get 8 columns. So □ = 8. Arrays make the unknown factor visible.",
      "cpa_phase": "pictorial",
      "visual_type": "manipulative",
      "visual_data": {
        "tool": "array_grid",
        "config": {
          "rows": 3,
          "cols": 8
        }
      }
    },
    {
      "id": "LN_04",
      "type": "concept_card",
      "title": "Division Is the Reverse",
      "content": "Finding an unknown factor is the same as dividing. If n × 6 = 42, then n = 42 ÷ 6 = 7. Division 'undoes' multiplication. You can always use this shortcut to solve quickly.",
      "cpa_phase": "abstract",
      "visual_type": "none"
    },
    {
      "id": "LN_05",
      "type": "concept_card",
      "title": "Always Check Your Answer",
      "content": "After finding the unknown factor, substitute it back: if n = 7, check n × 6 = 7 × 6 = 42 ✓. If it matches the product, your answer is correct. This works for any unknown factor equation.",
      "cpa_phase": "abstract",
      "visual_type": "none"
    }
  ],
