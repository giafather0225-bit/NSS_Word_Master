    { "id": "LN_01", "section": "learn", "difficulty": 0, "type": "concept_card",
      "title": "Identity Property of Multiplication",
      "content": "Any number multiplied by 1 equals that number. 8 × 1 = 8. 1 × 8 = 8. The number 1 is called the 'identity' because the number keeps its identity." },
    { "id": "LN_02", "section": "learn", "difficulty": 0, "type": "concept_card",
      "title": "Zero Property of Multiplication",
      "content": "Any number multiplied by 0 equals 0. 6 × 0 = 0. 0 × 6 = 0. Think: zero groups of anything = nothing!" },
    { "id": "LN_03", "section": "learn", "difficulty": 0, "type": "concept_card",
      "title": "Why These Properties Matter",
      "content": "These are the easiest multiplication facts! Any fact with 0 = 0. Any fact with 1 = the other number. This eliminates 19 facts from your times table instantly." },
