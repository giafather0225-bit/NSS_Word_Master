    { "id": "LN_01", "section": "learn", "difficulty": 0, "type": "concept_card",
      "title": "What is an Array?",
      "content": "An array is a way to show objects in equal rows and columns. Rows go across (left to right). Columns go up and down. Every row has the same number of objects." },
