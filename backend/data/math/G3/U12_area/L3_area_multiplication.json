  "pretest": [
    {"id": "PT_01", "type": "input", "cpa_phase": "abstract", "ccss": "3.MD.C.7", "skill_tag": "area_formula", "difficulty": 1, "question": "A rectangle is 5 cm long and 3 cm wide. What is its area? (Write the number of sq cm.)", "correct_answer": "15", "expected_errors": {"8": {"error_type": "concept_gap", "note": "5+3=8 but multiply"}, "16": {"error_type": "concept_gap", "note": "5×3=15"}}, "verification": "5×3=15.", "hints": ["Multiply length × width."], "feedback": {"correct": "Right!", "incorrect": "Area = 5 × 3 = 15 sq cm."}},
    {"id": "PT_02", "type": "mc", "cpa_phase": "abstract", "ccss": "3.MD.C.7", "skill_tag": "area_formula", "difficulty": 1, "question": "How do you find the area of a rectangle?", "choices": ["A) Add the sides", "B) Multiply length × width", "C) Divide longest by shortest", "D) Subtract width from length"], "correct_answer": "B", "expected_errors": {"A": {"error_type": "concept_gap", "note": "Adding sides = perimeter"}, "C": {"error_type": "concept_gap", "note": "Not a real formula"}, "D": {"error_type": "concept_gap", "note": "Not a real formula"}}, "verification": "Area = L × W.", "hints": ["Length times width."], "feedback": {"correct": "Right!", "incorrect": "Area = length × width."}},
    {"id": "PT_03", "type": "input", "cpa_phase": "abstract", "ccss": "3.MD.C.7", "skill_tag": "area_formula", "difficulty": 2, "question": "A rectangle is 7 m long and 4 m wide. Area in sq m?", "correct_answer": "28", "expected_errors": {"11": {"error_type": "concept_gap", "note": "7+4=11 but multiply"}, "21": {"error_type": "careless", "note": "7×3=21, but width is 4"}}, "verification": "7×4=28.", "hints": ["7 × 4."], "feedback": {"correct": "Right!", "incorrect": "Area = 7 × 4 = 28 sq m."}},
    {"id": "PT_04", "type": "input", "cpa_phase": "abstract", "ccss": "3.MD.C.7", "skill_tag": "area_formula", "difficulty": 2, "question": "A square has sides 6 cm. Area in sq cm?", "correct_answer": "36", "expected_errors": {"12": {"error_type": "concept_gap", "note": "6+6=12 but multiply"}, "24": {"error_type": "concept_gap", "note": "6×4=24 (perimeter)"}}, "verification": "6×6=36.", "hints": ["Side × side."], "feedback": {"correct": "Right!", "incorrect": "A square's area = side × side = 6 × 6 = 36 sq cm."}},
    {"id": "PT_05", "type": "mc", "cpa_phase": "abstract", "ccss": "3.MD.C.7", "skill_tag": "area_word", "difficulty": 3, "question": "Sara's rug is 8 ft by 5 ft. What is its area?", "choices": ["A) 13 sq ft", "B) 26 sq ft", "C) 40 sq ft", "D) 80 sq ft"], "correct_answer": "C", "expected_errors": {"A": {"error_type": "concept_gap", "note": "8+5=13 but multiply"}, "B": {"error_type": "concept_gap", "note": "(8+5)×2=26 — perimeter"}, "D": {"error_type": "concept_gap", "note": "8×10=80, but width is 5"}}, "verification": "8×5=40.", "hints": ["8 × 5."], "feedback": {"correct": "Right!", "incorrect": "Area = 8 × 5 = 40 sq ft."}}
  ],
  "learn": [
    {"id": "LEARN_01", "type": "concept_card", "cpa_phase": "concrete", "title": "Why Multiplication Works", "content": "When you cover a rectangle with unit squares, you make rows AND columns. The total = rows × squares-per-row. A rectangle with LENGTH L and WIDTH W has L × W unit squares — so its area = L × W.", "visual_type": "none", "visual_data": {}, "verification": "Go Math 11.6: foundation."},
    {"id": "LEARN_02", "type": "concept_card", "cpa_phase": "concrete", "title": "Length and Width", "content": "Rectangles have a LENGTH (the longer side, usually) and a WIDTH (the shorter side). Some books also say SIDE LENGTHS. To find area, you need both side lengths.", "visual_type": "none", "visual_data": {}, "verification": "Go Math 11.6: dimensions."},
    {"id": "LEARN_03", "type": "concept_card", "cpa_phase": "pictorial", "title": "Area Formula for Rectangle", "content": "FORMULA: Area = Length × Width (or A = L × W). Example: a 6 cm by 4 cm rectangle has area = 6 × 4 = 24 sq cm. The formula is a shortcut so we don't have to count every unit square.", "visual_type": "none", "visual_data": {}, "verification": "Go Math 11.6: formula."},
    {"id": "LEARN_04", "type": "concept_card", "cpa_phase": "pictorial", "title": "Area Formula for Square", "content": "A square is a special rectangle where length = width. So Area = side × side. Example: a square with side 5 cm has area = 5 × 5 = 25 sq cm.", "visual_type": "none", "visual_data": {}, "verification": "Go Math 11.6: square formula."},
    {"id": "LEARN_05", "type": "concept_card", "cpa_phase": "abstract", "title": "Units in Area", "content": "When sides are in cm, area is in sq cm. When sides are in m, area is in sq m. ALWAYS write the unit with the area: 24 sq cm, 50 sq m, 120 sq ft. Don't mix units (don't multiply 5 cm × 3 m).", "visual_type": "none", "visual_data": {}, "verification": "Go Math 11.6: units."},
    {"id": "LEARN_06", "type": "concept_card", "cpa_phase": "abstract", "title": "Order Doesn't Matter", "content": "Length × Width = Width × Length. A 4×7 rectangle has the same area as a 7×4 rectangle: both are 28 sq units. This is the COMMUTATIVE property.", "visual_type": "none", "visual_data": {}, "verification": "Go Math 11.6: commutative."},
    {"id": "LEARN_07", "type": "concept_card", "cpa_phase": "abstract", "title": "Find a Missing Side", "content": "If you know the area and one side, you can find the other side by dividing. Example: a rectangle has area 24 sq cm and length 6 cm. Width = 24 ÷ 6 = 4 cm.", "visual_type": "none", "visual_data": {}, "verification": "Go Math 11.6: missing side."},
    {"id": "LEARN_08", "type": "concept_card", "cpa_phase": "abstract", "title": "Lesson Summary", "content": "Today: (1) Area of rectangle = Length × Width. (2) Area of square = side × side. (3) Always include 'square' units. (4) Order doesn't matter (4×7 = 7×4). (5) To find a missing side: Area ÷ known side.", "visual_type": "none", "visual_data": {}, "verification": "Covers all Go Math 11.6."}
  ],
