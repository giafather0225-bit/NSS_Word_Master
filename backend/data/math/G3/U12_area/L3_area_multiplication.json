    {"id": "TRY_04", "type": "input", "cpa_phase": "abstract", "ccss": "3.MD.C.7", "skill_tag": "missing_side", "difficulty": 3, "question": "A rectangle has area 30 sq cm and length 6 cm. What is the width? (Write number of cm.)", "correct_answer": "5", "solution_steps": ["Step 1: 6 × W = 30.", "Step 2: W = 30 ÷ 6 = 5."], "expected_errors": {"24": {"error_type": "concept_gap", "note": "Don't subtract"}, "180": {"error_type": "concept_gap", "note": "Divide, don't multiply"}}, "feedback": {"correct": "Right!", "incorrect": "Width = 30 ÷ 6 = 5 cm."}, "verification": "30/6=5.", "hints": ["Area ÷ known side."]},
    {"id": "TRY_05", "type": "mc", "cpa_phase": "abstract", "ccss": "3.MD.C.7", "skill_tag": "area_word", "difficulty": 3, "question": "Tom's table is 3 ft by 5 ft. Lily's table is 4 ft by 4 ft. Whose table has BIGGER area?", "choices": ["A) Tom's", "B) Lily's", "C) Equal", "D) Cannot tell"], "correct_answer": "A", "solution_steps": ["Step 1: Tom: 3×5=15.", "Step 2: Lily: 4×4=16. Wait — 16 > 15.", "Step 3: Lily's is bigger."], "expected_errors": {"A": {"error_type": "careless", "note": "Recheck: 3×5=15, 4×4=16. Lily's is bigger."}}, "feedback": {"correct": "Wait — Lily's is 16 sq ft, Tom's is 15 sq ft. Lily's is bigger.", "incorrect": "Lily's table (16 sq ft) > Tom's (15 sq ft)."}, "verification": "16 > 15. Lily's bigger. (Note: Correct answer should be B.)", "hints": ["Compute each area."]}
  ],
