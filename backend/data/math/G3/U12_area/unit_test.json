        "B": {
          "error_type": "concept_gap",
          "note": "Frame adds 2 to each dimension"
        },
        "C": {
          "error_type": "concept_gap",
          "note": "5×7=35 but width and height each grow by 2 not 1"
        }
      },
      "feedback": {
        "correct": "Right! New dimensions: (4+2) × (6+2) = 6 × 8 = 48.",
        "incorrect": "Frame adds 1 unit on EACH side — both dimensions grow by 2. (4+2)×(6+2)=48."
