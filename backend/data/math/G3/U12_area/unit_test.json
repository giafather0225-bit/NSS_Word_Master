      "skill_tag": "area_word_problem",
      "difficulty": 5,
      "question": "Mia's poster is 4 unit squares wide and 6 unit squares tall. She buys a frame that covers an extra 1 unit square all around. What is the area of the framed poster (poster + frame)?",
      "choices": [
        "A) 24 sq units",
        "B) 30 sq units",
        "C) 35 sq units",
        "D) 48 sq units"
      ],
      "correct_answer": "D",
      "solution_steps": [
        "Step 1: Without frame: 4 × 6 = 24.",
        "Step 2: With 1 unit on every side: width becomes 4 + 2 = 6.",
        "Step 3: Height becomes 6 + 2 = 8.",
        "Step 4: New area = 6 × 8 = 48 sq units."
      ],
      "expected_errors": {
        "A": {
          "error_type": "concept_gap",
          "note": "That is the poster only — add frame"
