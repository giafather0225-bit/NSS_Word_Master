  "learn": [
    {
      "id": "LN_01",
      "type": "concept_card",
      "title": "Repeated Subtraction",
      "content": "Division can be shown by subtracting the same number until you reach 0. The number of times you subtract is the answer (quotient). Example: 18 ÷ 6 → subtract 6 three times to reach 0 → 18 ÷ 6 = 3.",
      "cpa_phase": "concrete",
      "visual_type": "manipulative",
      "visual_data": {
        "tool": "equation_display",
        "config": {
          "equations": [
            "18 − 6 = 12 (1st subtraction)",
            "12 − 6 = 6  (2nd subtraction)",
            "6 − 6 = 0   (3rd subtraction)",
            "18 ÷ 6 = 3"
          ]
        }
      }
    },
    {
      "id": "LN_02",
      "type": "concept_card",
      "title": "Step-by-Step Example",
      "content": "18 ÷ 6: Start with 18. Subtract 6: 18 − 6 = 12. Subtract 6: 12 − 6 = 6. Subtract 6: 6 − 6 = 0. You subtracted 3 times, so 18 ÷ 6 = 3.",
      "cpa_phase": "concrete",
      "visual_type": "manipulative",
      "visual_data": {
        "tool": "equation_display",
        "config": {
          "equations": [
            "18 → 12 → 6 → 0",
            "Count: 3 subtractions",
            "18 ÷ 6 = 3"
          ]
        }
      }
    },
    {
      "id": "LN_03",
      "type": "concept_card",
      "title": "Number Line Model",
      "content": "Start at the total on a number line. Jump back by the divisor. Count the jumps. For 20 ÷ 4: start at 20, jump back 4 five times: 20 → 16 → 12 → 8 → 4 → 0. Five jumps → 20 ÷ 4 = 5.",
      "cpa_phase": "pictorial",
      "visual_type": "number_line",
      "visual_data": {
