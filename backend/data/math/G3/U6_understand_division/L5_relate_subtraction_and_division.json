    {
      "id": "LN_05",
      "type": "concept_card",
      "title": "Subtraction and Division Are Related",
      "content": "Repeated subtraction and division always give the same answer. 24 ÷ 8: subtract 8 three times (24→16→8→0) OR use the related fact (8 × 3 = 24). Both show 24 ÷ 8 = 3. Division is a shortcut for repeated subtraction.",
      "cpa_phase": "abstract",
      "visual_type": "equation",
      "visual_data": {
        "tool": "equation_display",
        "config": {
          "equations": [
            "Repeated subtraction: 24 − 8 − 8 − 8 = 0 (3 times)",
