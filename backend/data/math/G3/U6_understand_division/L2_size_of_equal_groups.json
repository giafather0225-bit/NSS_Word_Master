  "learn": [
    {
      "id": "LN_01",
      "type": "concept_card",
      "title": "Finding the Size of Each Group",
      "content": "When you know the total and the number of groups, divide to find how many in each group. 28 ÷ 7 = 4 means 28 items in 7 groups = 4 in each.",
      "cpa_phase": "concrete",
      "visual_type": "manipulative",
      "visual_data": {
        "tool": "array_grid",
        "config": {
          "rows": 4,
          "cols": 7
        }
      }
    },
    {
      "id": "LN_02",
      "type": "concept_card",
      "title": "Using Counters",
      "content": "Put out 7 circles. Deal 28 counters one at a time into each circle. Keep going until all 28 are placed. Count how many in each circle: 4. So 28 ÷ 7 = 4.",
      "cpa_phase": "concrete",
      "visual_type": "manipulative",
      "visual_data": {
        "tool": "array_grid",
        "config": {
          "rows": 4,
          "cols": 7
        }
      }
    },
    {
      "id": "LN_03",
      "type": "concept_card",
      "title": "Check with Multiplication",
      "content": "If 28 ÷ 7 = 4, check: 7 × 4 = 28. ✓ Always verify: groups × size = total.",
      "cpa_phase": "pictorial",
      "visual_type": "manipulative",
      "visual_data": {
        "tool": "array_grid",
        "config": {
          "rows": 4,
