  "learn": [
    {
      "id": "LN_01",
      "type": "concept_card",
      "title": "Finding the Number of Groups",
      "content": "When you know the total and how many in each group, divide to find the number of groups. 24 ÷ 8 = 3 means 24 items, 8 in each group, makes 3 groups.",
      "cpa_phase": "concrete",
      "visual_type": "manipulative",
      "visual_data": {
        "tool": "array_grid",
        "config": {
          "rows": 3,
          "cols": 8
        }
      }
    },
    {
      "id": "LN_02",
      "type": "concept_card",
      "title": "Model It with Circles",
      "content": "For 35 ÷ 7: circle groups of 7 from 35 counters. First circle: 7. Second: 14. Third: 21. Fourth: 28. Fifth: 35. You make 5 circles. So 35 ÷ 7 = 5 groups.",
      "cpa_phase": "concrete",
      "visual_type": "manipulative",
      "visual_data": {
        "tool": "array_grid",
        "config": {
          "rows": 5,
          "cols": 7
        }
      }
    },
    {
      "id": "LN_03",
      "type": "concept_card",
      "title": "Skip Count Up",
      "content": "To find 36 ÷ 9: count by 9s → 9, 18, 27, 36. That's 4 counts. So 36 ÷ 9 = 4 groups. Skip counting shows you how many equal jumps fit into the total.",
      "cpa_phase": "pictorial",
      "visual_type": "number_line",
      "visual_data": {
        "tool": "number_line",
        "config": {
          "start": 0,
          "end": 36,
          "jump_size": 9,
          "num_jumps": 4
        }
      }
    },
    {
      "id": "LN_04",
      "type": "concept_card",
      "title": "Number Line: Counting Groups",
      "content": "Use a number line to find 24 ÷ 6. Start at 0, jump 6 each time: 0 → 6 → 12 → 18 → 24. Count the jumps: 4. So 24 ÷ 6 = 4 groups. Each jump is one group of 6.",
      "cpa_phase": "pictorial",
      "visual_type": "number_line",
      "visual_data": {
        "tool": "number_line",
        "config": {
          "start": 0,
          "end": 24,
          "jump_size": 6,
          "num_jumps": 4
        }
      }
    },
    {
      "id": "LN_05",
      "type": "concept_card",
      "title": "The Division Equation",
      "content": "When you know the total and size of each group, write: Total ÷ Each = Groups. Example: 35 total ÷ 7 each = 5 groups. Compare to finding group size: Total ÷ Groups = Each. Both use division — only the unknown changes.",
      "cpa_phase": "abstract",
      "visual_type": "equation",
      "visual_data": {
        "tool": "equation_display",
        "config": {
          "equations": [
            "Total ÷ Each = Groups",
            "35 ÷ 7 = 5",
            "Check: 7 × 5 = 35 ✓"
          ]
        }
      }
    }
  ],
