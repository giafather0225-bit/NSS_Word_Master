  "learn": [
    {
      "id": "LN_01",
      "type": "concept_card",
      "title": "Divide by 1",
      "content": "Any number divided by 1 equals itself. Think: if you have 8 items and make 1 group, all 8 are in that group. 8 ÷ 1 = 8. The number never changes when you divide by 1.",
      "cpa_phase": "concrete",
      "visual_type": "manipulative",
      "visual_data": {
        "tool": "bar_model",
        "config": {
          "total": 8,
          "parts": 1,
          "label": "8 ÷ 1 = 8  (1 group of 8)"
        }
      }
    },
    {
      "id": "LN_02",
      "type": "concept_card",
      "title": "Divide by Itself",
      "content": "Any number divided by itself equals 1. Think: if you have 8 items and split them into 8 groups, each group gets exactly 1. 8 ÷ 8 = 1. This works for every number (except 0).",
      "cpa_phase": "concrete",
      "visual_type": "manipulative",
      "visual_data": {
        "tool": "array_grid",
        "config": {
          "rows": 8,
          "cols": 1,
          "label": "8 ÷ 8 = 1  (8 groups of 1)"
        }
      }
    },
    {
      "id": "LN_03",
      "type": "concept_card",
      "title": "Zero in Division",
      "content": "0 divided by any number is 0. (0 ÷ 5 = 0 — zero items shared among groups gives zero each.) But you can NEVER divide by 0. There's no answer for 7 ÷ 0.",
      "cpa_phase": "pictorial",
      "visual_type": "diagram",
      "visual_data": {
        "tool": "counter_groups",
        "config": {
          "total": 0,
          "groups": 5,
          "label": "0 ÷ 5 = 0  (0 items in each group)"
        }
      }
    },
    {
      "id": "LN_04",
      "type": "concept_card",
      "title": "Seeing the Rules on a Number Line",
      "content": "7 ÷ 1 = 7: one jump of 7 → land on 7. 7 ÷ 7 = 1: seven jumps of 1 → land on 7 in 1 'group'. 0 ÷ 7 = 0: start at 0, zero jumps needed → quotient is 0.",
      "cpa_phase": "pictorial",
      "visual_type": "number_line",
      "visual_data": {
        "examples": [
          {
            "expression": "7 ÷ 1 = 7",
            "note": "1 group of 7"
          },
          {
            "expression": "7 ÷ 7 = 1",
            "note": "7 groups of 1"
          },
          {
            "expression": "0 ÷ 7 = 0",
            "note": "0 groups"
          }
        ]
      }
    },
    {
      "id": "LN_05",
      "type": "concept_card",
      "title": "The Four Division Rules",
      "content": "Rule 1: n ÷ 1 = n (any number ÷ 1 stays the same). Rule 2: n ÷ n = 1 (any number ÷ itself = 1). Rule 3: 0 ÷ n = 0 (zero divided by anything = 0). Rule 4: n ÷ 0 = undefined (you CANNOT divide by 0).",
      "cpa_phase": "abstract",
      "visual_type": "formula",
      "visual_data": {
        "rules": [
          "n ÷ 1 = n",
          "n ÷ n = 1",
          "0 ÷ n = 0",
          "n ÷ 0 = undefined"
        ],
        "examples": [
          "9 ÷ 1 = 9",
          "9 ÷ 9 = 1",
          "0 ÷ 9 = 0",
          "9 ÷ 0 = ?"
        ]
      }
    }
  ],
