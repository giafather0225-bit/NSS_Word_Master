    {
      "id": "LN_05",
      "type": "concept_card",
      "title": "The Inverse Rule",
      "content": "The rule: a ÷ b = ? is always the same as ? × b = a. Division is the 'undo' of multiplication. So if you know your multiplication facts, you can solve any division!",
      "cpa_phase": "abstract",
      "visual_type": "formula",
      "visual_data": {
        "formula": "a ÷ b = ?  ←→  ? × b = a",
        "example": "56 ÷ 7 = ?  →  ? × 7 = 56  →  8 × 7 = 56  →  answer: 8"
      }
    }
