  "learn": [
    {
      "id": "LN_01",
      "type": "concept_card",
      "title": "Arrays and Division",
      "content": "An array is objects arranged in equal rows and columns. You can use arrays to show division. 24 tiles in 4 rows means 24 ÷ 4 = 6 tiles per row.",
      "cpa_phase": "concrete",
      "visual_type": "manipulative",
      "visual_data": {
        "tool": "array_grid",
        "config": {
          "rows": 4,
          "cols": 6
        }
      }
    },
    {
      "id": "LN_02",
      "type": "concept_card",
      "title": "Building an Array",
      "content": "To solve 18 ÷ 3: make 3 rows with 18 tiles. Keep adding tiles evenly to each row. Each row gets 6 tiles. So 18 ÷ 3 = 6.",
      "cpa_phase": "concrete",
      "visual_type": "manipulative",
      "visual_data": {
        "tool": "array_grid",
        "config": {
          "rows": 3,
          "cols": 6
        }
      }
    },
    {
      "id": "LN_03",
      "type": "concept_card",
      "title": "One Array, Two Equations",
      "content": "The same array shows both multiplication and division: 4 × 6 = 24 and 24 ÷ 4 = 6. Flip it: 6 × 4 = 24 and 24 ÷ 6 = 4. They are related facts.",
      "cpa_phase": "pictorial",
      "visual_type": "diagram",
      "visual_data": {
        "tool": "array_grid",
        "config": {
          "rows": 4,
          "cols": 6,
          "label": "4 × 6 = 24  →  24 ÷ 4 = 6"
        }
      }
    },
    {
      "id": "LN_04",
      "type": "concept_card",
      "title": "Reading Division from an Array Diagram",
      "content": "Look at a 5 × 7 array (5 rows, 7 columns = 35 tiles). You can read two division facts: 35 ÷ 5 = 7 (find columns) and 35 ÷ 7 = 5 (find rows). The array picture makes both facts visible at once.",
      "cpa_phase": "pictorial",
      "visual_type": "diagram",
      "visual_data": {
        "tool": "array_grid",
        "config": {
          "rows": 5,
          "cols": 7,
          "label": "35 ÷ 5 = 7  |  35 ÷ 7 = 5"
        }
      }
    },
    {
      "id": "LN_05",
      "type": "concept_card",
      "title": "Division from Arrays: The Rule",
      "content": "For any array: rows × columns = total. So: total ÷ rows = columns, and total ÷ columns = rows. To find a missing side, divide the total by the side you know. Example: 6 × ? = 54 → 54 ÷ 6 = 9.",
      "cpa_phase": "abstract",
      "visual_type": "formula",
      "visual_data": {
        "formula": "rows × cols = total  →  total ÷ rows = cols",
        "example": "54 ÷ 6 = 9"
      }
    }
  ],
