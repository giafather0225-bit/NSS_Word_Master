              "label": "?",
              "value": 6
            }
          ]
        }
      }
    },
    {
      "id": "LN_05",
      "type": "concept_card",
      "title": "Parts of a Division Equation",
      "content": "In 18 ÷ 6 = 3: the dividend (18) is the total being divided; the divisor (6) is how many groups; the quotient (3) is how many in each group. Always ask: total ÷ groups = each.",
      "cpa_phase": "abstract",
      "visual_type": "equation",
      "visual_data": {
        "tool": "equation_display",
        "config": {
          "equations": [
            "18 ÷ 6 = 3",
            "dividend ÷ divisor = quotient",
            "total ÷ groups = each"
          ]
        }
      }
    }
