  "learn": [
    {
      "id": "LN_01",
      "type": "concept_card",
      "title": "What Is Division?",
      "content": "Division means sharing equally or making equal groups. 18 ÷ 6 means: put 18 into 6 equal groups — how many in each group?",
      "cpa_phase": "concrete",
      "visual_type": "manipulative",
      "visual_data": {
        "tool": "array_grid",
        "config": {
          "rows": 3,
          "cols": 6
        }
      }
    },
    {
      "id": "LN_02",
      "type": "concept_card",
      "title": "Model with Counters",
      "content": "To solve 18 ÷ 6: draw 6 circles. Place 1 counter in each, then repeat. When all 18 counters are used, count: 3 in each circle. So 18 ÷ 6 = 3.",
      "cpa_phase": "concrete",
      "visual_type": "manipulative",
      "visual_data": {
        "tool": "bar_model",
        "config": {
          "parts": [
