  "learn": [
    {
      "id": "LEARN_01",
      "type": "concept_card",
      "cpa_phase": "concrete",
      "title": "Three Types of Time Problems",
      "content": "Three common types: (1) Find END TIME (start + duration). (2) Find START TIME (end - duration). (3) Find DURATION (end - start).",
      "visual_type": "none",
      "visual_data": {},
      "verification": {
        "concept_source": "Go Math Grade 3 Ch.11 Lesson — U11_time_mass_volume/L3_time_word_problems",
        "procedure_source": "EngageNY Grade 3 Module 2 — U11_time_mass_volume",
        "assessment_source": "Smarter Balanced Grade 3 Mathematics Item Specifications 2015",
        "original_ref": "Strategy."
      },
      "cpa_stage": "concrete",
      "math_note": ""
    },
    {
      "id": "LEARN_02",
      "type": "concept_card",
      "cpa_phase": "concrete",
      "title": "Find End Time",
      "content": "Given START + DURATION → ADD. Example: starts 3:00, lasts 45 min. End: 3:00 + 45 = 3:45. Add minutes; if over 60, roll into the next hour.",
      "visual_type": "none",
      "visual_data": {},
      "verification": {
        "concept_source": "Go Math Grade 3 Ch.11 Lesson — U11_time_mass_volume/L3_time_word_problems",
        "procedure_source": "EngageNY Grade 3 Module 2 — U11_time_mass_volume",
        "assessment_source": "Smarter Balanced Grade 3 Mathematics Item Specifications 2015",
        "original_ref": "Add."
      },
      "cpa_stage": "concrete",
      "math_note": ""
    },
    {
      "id": "LEARN_03",
      "type": "concept_card",
      "cpa_phase": "pictorial",
      "title": "Find Start Time",
      "content": "Given END + DURATION → SUBTRACT. Example: ends 5:30, lasts 90 min. 5:30 - 1 hr = 4:30. - 30 more = 4:00. Subtract carefully.",
      "visual_type": "none",
      "visual_data": {},
      "verification": {
        "concept_source": "Go Math Grade 3 Ch.11 Lesson — U11_time_mass_volume/L3_time_word_problems",
        "procedure_source": "EngageNY Grade 3 Module 2 — U11_time_mass_volume",
        "assessment_source": "Smarter Balanced Grade 3 Mathematics Item Specifications 2015",
        "original_ref": "Subtract."
      },
      "cpa_stage": "pictorial",
      "math_note": ""
    },
    {
      "id": "LEARN_04",
      "type": "concept_card",
      "cpa_phase": "pictorial",
      "title": "Find Duration",
      "content": "Given START + END → SUBTRACT or count up. Example: 7:45 to 9:15. 7:45 → 8:00 = 15. 8:00 → 9:00 = 60. 9:00 → 9:15 = 15. Total: 90 min.",
      "visual_type": "none",
      "visual_data": {},
      "verification": {
        "concept_source": "Go Math Grade 3 Ch.11 Lesson — U11_time_mass_volume/L3_time_word_problems",
        "procedure_source": "EngageNY Grade 3 Module 2 — U11_time_mass_volume",
        "assessment_source": "Smarter Balanced Grade 3 Mathematics Item Specifications 2015",
        "original_ref": "Count up."
      },
      "cpa_stage": "pictorial",
      "math_note": ""
    },
    {
      "id": "LEARN_05",
      "type": "concept_card",
      "cpa_phase": "abstract",
      "title": "Read Carefully",
      "content": "Identify what's GIVEN and what's ASKED. Underline the start time, end time, and duration if mentioned. Decide which type of problem.",
