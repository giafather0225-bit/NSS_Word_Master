      "cpa_stage": "concrete",
      "math_note": ""
    },
    {
      "id": "LEARN_03",
      "type": "concept_card",
      "cpa_phase": "pictorial",
      "title": "Hop Strategy",
      "content": "(1) HOP TO THE NEXT HOUR first. Example: 2:45 → 3:00 = 15 min. (2) HOP IN HOURS until close to the end. (3) HOP IN MINUTES the rest of the way.",
      "visual_type": "none",
      "visual_data": {},
      "verification": {
        "concept_source": "Go Math Grade 3 Ch.11 Lesson — U11_time_mass_volume/L2_elapsed_time_number_line",
