  "learn": [
    {
      "id": "LEARN_01",
      "type": "concept_card",
      "cpa_phase": "concrete",
      "title": "What Is Elapsed Time?",
      "content": "ELAPSED TIME is how much time has PASSED between a START TIME and an END TIME. Example: a movie starts at 2:00 and ends at 3:30. Elapsed time = 1 hour and 30 minutes = 90 minutes.",
      "visual_type": "none",
      "visual_data": {},
      "verification": {
        "concept_source": "Go Math Grade 3 Ch.11 Lesson — U11_time_mass_volume/L2_elapsed_time_number_line",
        "procedure_source": "EngageNY Grade 3 Module 2 — U11_time_mass_volume",
        "assessment_source": "Smarter Balanced Grade 3 Mathematics Item Specifications 2015",
        "original_ref": "Go Math 10.2."
      },
      "cpa_stage": "concrete",
      "math_note": ""
    },
    {
      "id": "LEARN_02",
      "type": "concept_card",
      "cpa_phase": "concrete",
      "title": "Use a Number Line",
      "content": "Draw a NUMBER LINE. Mark the START time on the left, END time on the right. HOP from start to end in friendly steps (hours or minutes). Add up the hops.",
      "visual_type": "none",
      "visual_data": {},
      "verification": {
        "concept_source": "Go Math Grade 3 Ch.11 Lesson — U11_time_mass_volume/L2_elapsed_time_number_line",
        "procedure_source": "EngageNY Grade 3 Module 2 — U11_time_mass_volume",
        "assessment_source": "Smarter Balanced Grade 3 Mathematics Item Specifications 2015",
        "original_ref": "Go Math 10.2."
