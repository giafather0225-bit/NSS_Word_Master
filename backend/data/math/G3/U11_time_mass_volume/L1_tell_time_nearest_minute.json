  "learn": [
    {
      "id": "LEARN_01",
      "type": "concept_card",
      "cpa_phase": "concrete",
      "title": "Parts of a Clock",
      "content": "An ANALOG clock has two hands: the SHORT one is the HOUR HAND. The LONG one is the MINUTE HAND. Numbers 1-12 are around the clock face. (Some clocks also have a thin SECOND hand.)",
      "visual_type": "none",
      "visual_data": {},
      "verification": {
        "concept_source": "Go Math Grade 3 Ch.11 Lesson — U11_time_mass_volume/L1_tell_time_nearest_minute",
        "procedure_source": "EngageNY Grade 3 Module 2 — U11_time_mass_volume",
        "assessment_source": "Smarter Balanced Grade 3 Mathematics Item Specifications 2015",
        "original_ref": "Go Math 10.1."
      },
      "cpa_stage": "concrete",
      "math_note": ""
    },
    {
      "id": "LEARN_02",
      "type": "concept_card",
      "cpa_phase": "concrete",
      "title": "Hour and Minute Numbers",
      "content": "1 HOUR = 60 MINUTES. Each NUMBER on the clock face = 5 MINUTES (because 60÷12=5). So the minute hand on '3' means 15 minutes. On '6' means 30 minutes. On '9' means 45 minutes.",
      "visual_type": "none",
      "visual_data": {},
      "verification": {
        "concept_source": "Go Math Grade 3 Ch.11 Lesson — U11_time_mass_volume/L1_tell_time_nearest_minute",
        "procedure_source": "EngageNY Grade 3 Module 2 — U11_time_mass_volume",
        "assessment_source": "Smarter Balanced Grade 3 Mathematics Item Specifications 2015",
        "original_ref": "Go Math 10.1."
      },
      "cpa_stage": "concrete",
      "math_note": ""
    },
    {
      "id": "LEARN_03",
      "type": "concept_card",
      "cpa_phase": "pictorial",
      "title": "Reading the Hour",
      "content": "The HOUR HAND tells you the hour. If the hour hand points BETWEEN 4 and 5, the hour is 4 (because the hour hasn't reached 5 yet). Always say the LOWER hour.",
      "visual_type": "none",
      "visual_data": {},
      "verification": {
        "concept_source": "Go Math Grade 3 Ch.11 Lesson — U11_time_mass_volume/L1_tell_time_nearest_minute",
        "procedure_source": "EngageNY Grade 3 Module 2 — U11_time_mass_volume",
        "assessment_source": "Smarter Balanced Grade 3 Mathematics Item Specifications 2015",
        "original_ref": "Go Math 10.1."
      },
      "cpa_stage": "pictorial",
      "math_note": ""
    },
    {
      "id": "LEARN_04",
      "type": "concept_card",
      "cpa_phase": "pictorial",
      "title": "Reading the Minutes",
      "content": "Count by 5s starting from 12. 12=0 min, 1=5 min, 2=10 min, 3=15 min, 4=20 min, 5=25 min, 6=30 min, 7=35, 8=40, 9=45, 10=50, 11=55. If the minute hand is between numbers, count 1-by-1 (5 small ticks per number).",
      "visual_type": "none",
      "visual_data": {},
      "verification": {
        "concept_source": "Go Math Grade 3 Ch.11 Lesson — U11_time_mass_volume/L1_tell_time_nearest_minute",
        "procedure_source": "EngageNY Grade 3 Module 2 — U11_time_mass_volume",
        "assessment_source": "Smarter Balanced Grade 3 Mathematics Item Specifications 2015",
        "original_ref": "Go Math 10.1."
      },
      "cpa_stage": "pictorial",
      "math_note": ""
    },
    {
      "id": "LEARN_05",
      "type": "concept_card",
      "cpa_phase": "pictorial",
      "title": "Nearest Minute",
      "content": "To tell time to the NEAREST MINUTE, count by 5s up to the nearest small tick, then add the extra ticks. Example: minute hand 1 tick past the 7 → 35 + 1 = 36 minutes.",
      "visual_type": "none",
      "visual_data": {},
      "verification": {
        "concept_source": "Go Math Grade 3 Ch.11 Lesson — U11_time_mass_volume/L1_tell_time_nearest_minute",
        "procedure_source": "EngageNY Grade 3 Module 2 — U11_time_mass_volume",
        "assessment_source": "Smarter Balanced Grade 3 Mathematics Item Specifications 2015",
        "original_ref": "Go Math 10.1."
      },
      "cpa_stage": "pictorial",
      "math_note": ""
    },
    {
      "id": "LEARN_06",
      "type": "concept_card",
      "cpa_phase": "abstract",
      "title": "Writing Time",
      "content": "Write time as HH:MM. Example: 3 hours and 25 minutes = 3:25. The hour goes first, then a colon, then the minutes (always two digits — like 3:05, not 3:5).",
      "visual_type": "none",
      "visual_data": {},
      "verification": {
