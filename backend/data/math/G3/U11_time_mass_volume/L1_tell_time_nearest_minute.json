    },
    {
      "id": "LEARN_07",
      "type": "concept_card",
      "cpa_phase": "abstract",
      "title": "A.M. and P.M.",
      "content": "A.M. = before noon (midnight to noon, 12:00 A.M. to 11:59 A.M.). P.M. = after noon (noon to midnight, 12:00 P.M. to 11:59 P.M.). Morning = A.M. Afternoon/evening = P.M.",
      "visual_type": "none",
      "visual_data": {},
      "verification": {
        "concept_source": "Go Math Grade 3 Ch.11 Lesson — U11_time_mass_volume/L1_tell_time_nearest_minute",
        "procedure_source": "EngageNY Grade 3 Module 2 — U11_time_mass_volume",
        "assessment_source": "Smarter Balanced Grade 3 Mathematics Item Specifications 2015",
        "original_ref": "Go Math 10.1."
      },
      "cpa_stage": "abstract",
      "math_note": ""
    },
    {
      "id": "LEARN_08",
      "type": "concept_card",
      "cpa_phase": "abstract",
      "title": "Lesson Summary",
      "content": "Today: (1) Hour hand short, minute hand long. (2) Each number = 5 minutes. (3) Hour = lower of two numbers the hour hand is between. (4) Count by 5s for minutes; add extra ticks for nearest minute. (5) Write as HH:MM. (6) A.M. = morning, P.M. = afternoon/evening.",
      "visual_type": "none",
