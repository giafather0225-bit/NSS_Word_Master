  "learn": [
    {"id": "LEARN_01", "type": "concept_card", "cpa_phase": "concrete", "title": "Three Types of Measurement", "content": "TIME = how long. MASS = how heavy. VOLUME = how much liquid. Each uses different units.", "visual_type": "none", "visual_data": {}, "verification": "Recap."},
    {"id": "LEARN_02", "type": "concept_card", "cpa_phase": "concrete", "title": "Time Recap", "content": "Hour, minute. 1 hour = 60 minutes. Use elapsed time on a number line. Add hours and minutes; roll over at 60.", "visual_type": "none", "visual_data": {}, "verification": "Recap L1-L3."},
    {"id": "LEARN_03", "type": "concept_card", "cpa_phase": "concrete", "title": "Mass Recap", "content": "Gram (g), kilogram (kg). 1 kg = 1000 g. Use grams for small, kg for big. Use balance to measure.", "visual_type": "none", "visual_data": {}, "verification": "Recap L4-L5."},
    {"id": "LEARN_04", "type": "concept_card", "cpa_phase": "concrete", "title": "Volume Recap", "content": "Liter (L), milliliter (mL). 1 L = 1000 mL. Use mL for small, L for big.", "visual_type": "none", "visual_data": {}, "verification": "Recap L6-L7."},
    {"id": "LEARN_05", "type": "concept_card", "cpa_phase": "abstract", "title": "Same Operations", "content": "All three (time, mass, volume) use ADD, SUBTRACT, MULTIPLY, DIVIDE in word problems. Look for keywords: 'total', 'left', 'each', 'shared'.", "visual_type": "none", "visual_data": {}, "verification": "Strategy."},
    {"id": "LEARN_06", "type": "concept_card", "cpa_phase": "abstract", "title": "Match Units", "content": "Always check units. If problem mixes 1 kg and 200 g, convert before computing. 1 kg = 1000 g, so total = 1000 + 200 = 1200 g.", "visual_type": "none", "visual_data": {}, "verification": "Strategy."},
    {"id": "LEARN_07", "type": "concept_card", "cpa_phase": "abstract", "title": "Estimate First", "content": "Always estimate. A juice box is mL not L. A person is kg not g. A movie is hours, not seconds. Keep answers reasonable.", "visual_type": "none", "visual_data": {}, "verification": "Strategy."},
    {"id": "LEARN_08", "type": "concept_card", "cpa_phase": "abstract", "title": "Lesson Summary", "content": "Today: (1) Time, mass, volume — different units, similar operations. (2) Convert when units differ. (3) Estimate to check answers. (4) Use add/subtract/multiply/divide based on the problem.", "visual_type": "none", "visual_data": {}, "verification": "Summary."}
