  ],
  "learn": [
    {"id": "LEARN_01", "type": "concept_card", "cpa_phase": "concrete", "title": "Volume Problems Like Mass", "content": "Volume word problems use the same operations as mass: ADD for total, SUBTRACT for difference/left, MULTIPLY for equal groups, DIVIDE for equal sharing.", "visual_type": "none", "visual_data": {}, "verification": "Strategy."},
    {"id": "LEARN_02", "type": "concept_card", "cpa_phase": "concrete", "title": "Match Units First", "content": "Always check that volumes are in the same unit (all mL or all L). Convert if needed: 1 L = 1000 mL.", "visual_type": "none", "visual_data": {}, "verification": "Strategy."},
    {"id": "LEARN_03", "type": "concept_card", "cpa_phase": "pictorial", "title": "Combining Volumes", "content": "When you POUR multiple containers together: ADD their volumes. Example: 200 mL + 300 mL = 500 mL.", "visual_type": "none", "visual_data": {}, "verification": "Strategy."},
    {"id": "LEARN_04", "type": "concept_card", "cpa_phase": "pictorial", "title": "Pouring Out", "content": "When you POUR OUT from a container: SUBTRACT what was poured. Example: 1 L = 1000 mL. Pour out 400 mL → 1000-400=600 mL left.", "visual_type": "none", "visual_data": {}, "verification": "Strategy."},
    {"id": "LEARN_05", "type": "concept_card", "cpa_phase": "abstract", "title": "Equal Servings", "content": "If you have a TOTAL volume to divide into equal servings: DIVIDE. Example: 2 L into 4 cups → 500 mL each.", "visual_type": "none", "visual_data": {}, "verification": "Strategy."},
    {"id": "LEARN_06", "type": "concept_card", "cpa_phase": "abstract", "title": "Multiplying Equal Volumes", "content": "If many containers each hold the same volume: MULTIPLY. Example: 6 bottles × 500 mL each = 3000 mL = 3 L.", "visual_type": "none", "visual_data": {}, "verification": "Strategy."},
    {"id": "LEARN_07", "type": "concept_card", "cpa_phase": "abstract", "title": "Read Carefully and Estimate", "content": "Read the problem carefully. Estimate the answer first. If a problem says 'one glass', the answer should be in mL or 1 L, not 100 L.", "visual_type": "none", "visual_data": {}, "verification": "Strategy."},
    {"id": "LEARN_08", "type": "concept_card", "cpa_phase": "abstract", "title": "Lesson Summary", "content": "Today: (1) Use add, subtract, multiply, divide. (2) Match units first. (3) Adding combines; subtracting takes away. (4) Multiply for equal groups, divide for equal sharing. (5) Estimate before computing.", "visual_type": "none", "visual_data": {}, "verification": "Summary."}
  ],
