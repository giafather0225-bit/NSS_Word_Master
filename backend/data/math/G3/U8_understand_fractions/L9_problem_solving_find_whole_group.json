    "learn": [
      {
        "id": "LRN_01",
        "type": "card",
        "title": "From Part to Whole",
        "content": "If you know a unit fraction of a group, you can find the whole group by multiplying. Example: 1/4 of a group is 6. The whole group = 6 × 4 = 24."
      },
      {
        "id": "LRN_02",
        "type": "card",
        "title": "Why Multiply?",
        "content": "A unit fraction like 1/4 means the whole is made of 4 equal parts. If 1 part = 6, then 4 parts = 6 + 6 + 6 + 6 = 24. Multiplying is a shortcut: 6 × 4 = 24."
      },
      {
        "id": "LRN_03",
        "type": "card",
        "title": "Check Your Answer",
        "content": "After finding the whole, check by dividing. If the whole is 24 and the fraction is 1/4, then 24 ÷ 4 = 6. That matches the given part, so the answer is correct."
      }
    ],
