  "essential_question": "How can you find the total number in a group when you know a unit fraction of the group?",
  "key_vocabulary": [
    "unit fraction",
    "whole group",
    "multiply",
    "equal groups"
  ],
  "strategies": [
    "if 1/n of the group = a known number, multiply that number by n to find the whole"
  ],
