    "learn": [
      {
        "id": "LRN_01",
        "type": "card",
        "title": "Finding a Unit Fraction of a Group",
        "content": "To find a unit fraction of a group, divide the total number of items by the denominator. Example: 1/3 of 12 → 12 ÷ 3 = 4."
      },
      {
        "id": "LRN_02",
        "type": "card",
        "title": "Using Equal Groups",
        "content": "Think of dividing items into equal groups. 1/4 of 20 means: make 4 equal groups from 20. Each group has 20 ÷ 4 = 5 items. One group is 1/4 of the total."
      },
      {
        "id": "LRN_03",
        "type": "card",
        "title": "Connection to Division",
        "content": "Finding a unit fraction of a number is the same as division. 1/2 of 10 = 10 ÷ 2 = 5. 1/6 of 18 = 18 ÷ 6 = 3."
      }
    ],
