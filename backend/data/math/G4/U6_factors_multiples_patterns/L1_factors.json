      "title": "Factor List for 12",
      "content": "12 = 1×12, 2×6, 3×4. Factors: 1, 2, 3, 4, 6, 12.",
      "visual_type": "none",
      "visual_data": {},
      "tts": "12 = 1×12, 2×6, 3×4. Factors: 1, 2, 3, 4, 6, 12."
    },
    {
      "id": "LRN_04",
      "type": "concept_card",
      "cpa_phase": "pictorial",
      "title": "Divisibility Test",
      "content": "To check if n is a factor of m, divide m÷n. If the result is whole, n is a factor.",
      "visual_type": "none",
      "visual_data": {},
      "tts": "To check if n is a factor of m, divide m÷n. If the result is whole, n is a factor."
    },
    {
      "id": "LRN_05",
      "type": "concept_card",
      "cpa_phase": "abstract",
      "title": "Every Number Has 1 and Itself",
      "content": "1 divides every number; every number divides itself. So 1 and n are always factors of n.",
      "visual_type": "none",
      "visual_data": {},
      "tts": "1 divides every number; every number divides itself. So 1 and n are always factors of n."
    },
