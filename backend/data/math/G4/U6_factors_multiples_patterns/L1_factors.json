  "learn": [
    {
      "id": "LRN_01",
      "type": "concept_card",
      "cpa_phase": "concrete",
      "title": "What is a Factor?",
      "content": "A factor is a whole number that divides evenly into another number with no remainder.",
      "visual_type": "none",
      "visual_data": {},
      "tts": "A factor is a whole number that divides evenly into another number with no remainder."
    },
    {
      "id": "LRN_02",
      "type": "concept_card",
      "cpa_phase": "concrete",
      "title": "Arrays Show Factors",
      "content": "If you can make a rectangle with that many squares, the side lengths are factors.",
      "visual_type": "manipulative",
      "visual_data": {
        "tool": "array_grid",
        "config": {
