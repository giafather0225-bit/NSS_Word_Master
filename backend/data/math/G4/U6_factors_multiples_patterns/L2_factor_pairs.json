      "type": "instruction",
      "cpa_phase": "concrete",
      "title": "Find All Pairs",
      "content": "Start with 1 × n. Then 2 × (n÷2) if it divides. Keep going until pairs repeat.",
      "visual_type": "none",
      "visual_data": {},
      "tts": "Start with 1 × n. Then 2 × (n÷2) if it divides. Keep going until pairs repeat."
