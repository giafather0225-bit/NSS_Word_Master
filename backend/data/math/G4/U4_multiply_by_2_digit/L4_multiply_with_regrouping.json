  "learn": [
    {
      "id": "LRN_01",
      "type": "concept_card",
      "cpa_phase": "concrete",
      "title": "Regrouping",
      "content": "When a place-value product is 10 or more, you 'carry' the tens to the next column.",
      "visual_type": "none",
      "visual_data": {},
      "tts": "When a place-value product is 10 or more, you 'carry' the tens to the next column."
    },
    {
      "id": "LRN_02",
      "type": "concept_card",
      "cpa_phase": "concrete",
      "title": "Multiply Ones First",
      "content": "Start at the ones place. If the product is ≥ 10, write the ones digit and carry the tens digit.",
      "visual_type": "none",
      "visual_data": {},
      "tts": "Start at the ones place. If the product is ≥ 10, write the ones digit and carry the tens digit."
    },
    {
      "id": "LRN_03",
      "type": "concept_card",
      "cpa_phase": "pictorial",
      "title": "Base-Ten Blocks View",
      "content": "Think of 3 × 24 as 3 groups of 2 tens + 4 ones = 6 tens + 12 ones = 7 tens + 2 ones = 72.",
      "visual_type": "manipulative",
      "visual_data": {
        "tool": "base10_blocks",
        "config": {
          "ones": 12,
          "tens": 6
        }
      },
      "tts": "Think of 3 × 24 as 3 groups of 2 tens + 4 ones = 6 tens + 12 ones = 7 tens + 2 ones = 72."
    },
    {
      "id": "LRN_04",
      "type": "concept_card",
      "cpa_phase": "pictorial",
      "title": "Example: 8 × 37",
      "content": "8×7=56, write 6 carry 5. 8×3=24, +5=29. Write 29 → 296.",
      "visual_type": "none",
      "visual_data": {},
      "tts": "8×7=56, write 6 carry 5. 8×3=24, +5=29. Write 29 → 296."
    },
    {
      "id": "LRN_05",
