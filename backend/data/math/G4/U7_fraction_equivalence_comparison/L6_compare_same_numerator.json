      "type": "instruction",
      "cpa_phase": "concrete",
      "title": "Same Numerator Rule",
      "content": "When numerators are equal, the fraction with the SMALLER denominator is LARGER.",
      "visual_type": "none",
      "visual_data": {},
      "tts": "When numerators are equal, the fraction with the SMALLER denominator is LARGER."
    },
    {
      "id": "LRN_02",
