      "type": "concept_card",
      "cpa_phase": "concrete",
      "title": "Benchmark 1/2",
      "content": "1/2 is a useful reference point. Many fractions are easy to judge against it.",
      "visual_type": "none",
      "visual_data": {},
      "tts": "1/2 is a useful reference point. Many fractions are easy to judge against it."
    },
    {
      "id": "LRN_02",
      "type": "concept_card",
      "cpa_phase": "concrete",
      "title": "Check Half the Denominator",
      "content": "If numerator > half of denominator, fraction > 1/2. If <, then fraction < 1/2.",
      "visual_type": "manipulative",
      "visual_data": {
        "tool": "fraction_bar",
        "config": {
          "numerator": 1,
          "denominator": 2
        }
      },
      "tts": "If numerator > half of denominator, fraction > 1/2. If <, then fraction < 1/2."
    },
    {
      "id": "LRN_03",
      "type": "concept_card",
      "cpa_phase": "pictorial",
      "title": "Example",
      "content": "3/8 vs 1/2? Half of 8 is 4. Numerator 3 < 4, so 3/8 < 1/2.",
      "visual_type": "none",
      "visual_data": {},
