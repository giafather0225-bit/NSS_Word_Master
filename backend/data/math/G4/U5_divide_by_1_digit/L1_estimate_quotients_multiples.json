    {
      "id": "LRN_02",
      "type": "instruction",
      "cpa_phase": "concrete",
      "title": "Find a Close Multiple",
      "content": "For 62 ÷ 8, find a multiple of 8 near 62. 8×8=64, so 62÷8 ≈ 8.",
      "visual_type": "none",
      "visual_data": {},
      "tts": "For 62 ÷ 8, find a multiple of 8 near 62. 8×8=64, so 62÷8 ≈ 8."
