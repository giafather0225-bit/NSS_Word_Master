  "essential_question": "How can you describe the value of a digit in a multi-digit whole number?",
  "key_vocabulary": ["place value", "digit", "period", "thousands", "ten thousands", "hundred thousands", "expanded form"],
  "strategies": ["place_value_chart", "ten_times_rule"],

  "pretest": [
    { "id": "PT_01", "type": "multiple_choice",
      "question": "In the number 4,572, what is the value of the digit 5?",
      "choices": ["A. 5", "B. 50", "C. 500", "D. 5,000"], "answer": "C",
      "solution_steps": ["4,572 → thousands:4, hundreds:5, tens:7, ones:2", "The 5 is in the hundreds place → 5 × 100 = 500"],
      "hint": "Which place is the 5 sitting in?", "difficulty": 2,
      "ccss": "4.NBT.A.1", "cpa_stage": "abstract", "skill_tag": "place_value_identify" },
    { "id": "PT_02", "type": "multiple_choice",
      "question": "The digit 7 in 7,000 is how many times the value of the 7 in 700?",
      "choices": ["A. 1", "B. 10", "C. 100", "D. 1,000"], "answer": "B",
      "solution_steps": ["7 in 7,000 = 7,000", "7 in 700 = 700", "7,000 ÷ 700 = 10"],
      "hint": "A digit one place to the LEFT is 10 times as much.", "difficulty": 2,
      "ccss": "4.NBT.A.1", "cpa_stage": "abstract", "skill_tag": "ten_times_rule" },
    { "id": "PT_03", "type": "multiple_choice",
      "question": "Which number has an 8 in the ten thousands place?",
      "choices": ["A. 28,403", "B. 82,154", "C. 18,732", "D. 408,500"], "answer": "B",
      "solution_steps": ["Ten thousands is the 5th digit from the right.", "82,154 → 8 ten thousands. Correct."],
      "hint": "Count the places from the ones.", "difficulty": 2,
      "ccss": "4.NBT.A.1", "cpa_stage": "abstract", "skill_tag": "place_value_identify" },
    { "id": "PT_04", "type": "multiple_choice",
      "question": "What is 30,000 written as expanded form of 3?",
      "choices": ["A. 3 × 10", "B. 3 × 100", "C. 3 × 1,000", "D. 3 × 10,000"], "answer": "D",
      "solution_steps": ["3 sits in the ten thousands place in 30,000.", "So 30,000 = 3 × 10,000."],
      "hint": "Count the zeros.", "difficulty": 2,
      "ccss": "4.NBT.A.1", "cpa_stage": "abstract", "skill_tag": "expanded_form" },
    { "id": "PT_05", "type": "multiple_choice",
      "question": "The 6 in 162,489 is how many times the 6 in 46,700?",
      "choices": ["A. 10", "B. 100", "C. 1,000", "D. The same"], "answer": "A",
      "solution_steps": ["162,489 → 6 is in ten thousands (60,000)", "46,700 → 6 is in thousands (6,000)", "60,000 ÷ 6,000 = 10"],
      "hint": "Compare places, one step to the left.", "difficulty": 3,
      "ccss": "4.NBT.A.1", "cpa_stage": "abstract", "skill_tag": "ten_times_rule" }
  ],

  "learn": [
    { "id": "LEARN_01", "type": "concept_card",
      "title": "The Place Value Chart",
      "content": "Whole numbers are grouped into periods of three digits: ones, thousands, millions. Each period has hundreds, tens, and ones.",
      "visual_type": "place_value_chart", "cpa_stage": "pictorial" },
    { "id": "LEARN_02", "type": "concept_card",
      "title": "Same Digit, Different Value",
      "content": "The digit 4 in 4,000 is worth 4,000. The digit 4 in 400 is worth 400. Position is what matters — the digit name alone doesn't tell you the value.",
      "visual_type": "comparison_table", "cpa_stage": "pictorial" },
    { "id": "LEARN_03", "type": "concept_card",
      "title": "The 10-Times Rule",
      "content": "A digit in any place is 10 times the value of the same digit one place to its right. Example: the 7 in 7,000 is 10 times the 7 in 700.",
      "visual_type": "step_by_step", "cpa_stage": "abstract" },
    { "id": "LEARN_04", "type": "concept_card",
      "title": "Expanded Form",
      "content": "Write a number as a sum of each digit's value. 2,413 = 2,000 + 400 + 10 + 3 = (2 × 1,000) + (4 × 100) + (1 × 10) + (3 × 1).",
      "visual_type": "step_by_step", "cpa_stage": "abstract" },
    { "id": "LEARN_05", "type": "concept_card",
      "title": "Common Mistake: Digit vs. Value",
      "content": "'The DIGIT 5 in 4,572' answers 5. 'The VALUE of the 5 in 4,572' answers 500. Read carefully!",
      "visual_type": "error_highlight", "cpa_stage": "abstract" }
  ],

  "try": [
