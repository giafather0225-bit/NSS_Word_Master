  "problems": [
    {"id":"e2_01","type":"mc",
     "question":"The sum of three consecutive numbers is 24. What is the smallest?",
     "options":["6","7","8","9"],"answer":"7",
     "feedback_wrong":"7 + 8 + 9 = 24. Smallest is 7."},
    {"id":"e2_02","type":"mc",
     "question":"A farmer has chickens and cows. There are 10 heads and 28 legs. How many cows?",
     "options":["4","5","6","8"],"answer":"4",
     "feedback_wrong":"If all were chickens: 20 legs. Extra 8 legs ÷ 2 = 4 cows."},
    {"id":"e2_03","type":"mc",
     "question":"Which number has digits that add to 9 and is between 50 and 60?",
     "options":["54","55","56","57"],"answer":"54",
     "feedback_wrong":"5 + 4 = 9."},
    {"id":"e2_04","type":"mc",
     "question":"A box has 4 red marbles and 6 blue marbles. What fraction are red?",
     "options":["4/10","6/10","4/6","1/4"],"answer":"4/10",
     "feedback_wrong":"4 red out of 10 total = 4/10."},
    {"id":"e2_05","type":"mc",
     "question":"If 7 × 8 = 56, what is 56 ÷ 7?",
     "options":["6","7","8","9"],"answer":"8",
     "feedback_wrong":"Multiplication and division are inverses: 56 ÷ 7 = 8."},
    {"id":"e2_06","type":"mc",
     "question":"A square has side length 5 cm. What is its area?",
     "options":["10","15","20","25"],"answer":"25",
     "feedback_wrong":"Area of a square = side × side = 5 × 5 = 25."},
    {"id":"e2_07","type":"mc",
     "question":"Which number is 100 more than 289?",
     "options":["290","299","389","489"],"answer":"389",
     "feedback_wrong":"289 + 100 = 389."},
    {"id":"e2_08","type":"mc",
     "question":"There are 24 cookies and 3 children. If shared equally, each gets:",
     "options":["6","7","8","9"],"answer":"8",
     "feedback_wrong":"24 ÷ 3 = 8."},
    {"id":"e2_09","type":"mc",
     "question":"Tim counts by 4s starting from 3: 3, 7, 11, 15… What's the 6th number?",
     "options":["19","23","27","31"],"answer":"23",
     "feedback_wrong":"Each step adds 4. 6th = 3 + 5·4 = 23."},
    {"id":"e2_10","type":"mc",
     "question":"Which fraction is equivalent to 1/2?",
     "options":["2/3","3/6","4/5","5/8"],"answer":"3/6",
     "feedback_wrong":"3/6 = 1/2 (both numerator and denominator divide by 3)."}
  ]
