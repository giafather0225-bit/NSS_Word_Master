  "problems": [
    {"id":"b1_01","type":"mc",
     "question":"What is the value of 2 × 3 + 4 × 5?",
     "options":["26","30","50","70"],"answer":"26",
     "feedback_wrong":"Multiply first: 6 + 20 = 26."},
    {"id":"b1_02","type":"mc",
     "question":"A rectangle has area 48 cm² and width 6 cm. What is its length?",
     "options":["6","7","8","9"],"answer":"8",
     "feedback_wrong":"Length = Area ÷ Width = 48 ÷ 6 = 8."},
    {"id":"b1_03","type":"mc",
     "question":"What is 1/2 + 1/4?",
     "options":["1/6","2/6","3/4","2/4"],"answer":"3/4",
     "feedback_wrong":"1/2 = 2/4, so 2/4 + 1/4 = 3/4."},
    {"id":"b1_04","type":"mc",
     "question":"Sam spends 2/5 of $25 on a book. How much does the book cost?",
     "options":["$5","$10","$15","$20"],"answer":"$10",
     "feedback_wrong":"1/5 of 25 = 5. Then 2/5 = 10."},
    {"id":"b1_05","type":"mc",
     "question":"How many whole minutes are in 2 hours and 15 minutes?",
     "options":["125","130","135","145"],"answer":"135",
     "feedback_wrong":"2 × 60 + 15 = 135."},
    {"id":"b1_06","type":"mc",
     "question":"Which is the smallest: 0.4, 0.35, 0.5, 0.45?",
     "options":["0.4","0.35","0.5","0.45"],"answer":"0.35",
     "feedback_wrong":"Compare hundredths: 0.35 is smallest."},
    {"id":"b1_07","type":"mc",
     "question":"A cube has all sides equal to 3 cm. What is its volume?",
     "options":["9","18","27","36"],"answer":"27",
     "feedback_wrong":"Volume = 3 × 3 × 3 = 27 cm³."},
    {"id":"b1_08","type":"mc",
     "question":"In a class of 30, 60% are girls. How many boys?",
     "options":["8","12","15","18"],"answer":"12",
     "feedback_wrong":"60% girls = 18. Boys = 30 − 18 = 12."},
    {"id":"b1_09","type":"mc",
     "question":"What is the next number? 2, 6, 12, 20, 30, ___",
     "options":["36","40","42","44"],"answer":"42",
     "feedback_wrong":"Differences are 4, 6, 8, 10, so next adds 12: 30 + 12 = 42."},
    {"id":"b1_10","type":"mc",
     "question":"A bag has 5 red and 3 blue marbles. What fraction are NOT red?",
     "options":["3/5","3/8","5/8","5/3"],"answer":"3/8",
     "feedback_wrong":"Not red = 3 out of 8 total = 3/8."}
  ]
}
