# ── AI API Keys ──
GEMINI_API_KEY=your_gemini_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Ollama Settings ──
OLLAMA_HOST=http://localhost:11434
OLLAMA_OCR_MODEL=llava
OLLAMA_TUTOR_MODEL=llama3
OLLAMA_VISION_MODEL=llava
OLLAMA_ENRICH_MODEL=llama3

# ── CORS (comma-separated origins) ──
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# ── Reward Shop / Parent PIN ──
# Initial PIN used on fresh install (before the parent sets a new one via UI).
# Change this from "0000" before deploying and after first run.
DEFAULT_PIN=0000
