# JS 빌드 산출물 — 이제 git에 커밋함
# 이유: 딸 Mac에는 node/npm이 없어 build.sh가 실패함. 번들을 커밋하면
# git pull만으로 최신 JS가 즉시 반영됨. dad는 JS 수정 후 반드시
# `bash build.sh && git add frontend/static/js/bundle-*.min.js`로 함께 커밋.

# esbuild 빌드 중간 산물 (임시 파일, 자동 삭제되나 간혹 잔류)
frontend/static/js/bundle-*.min.js.*

# 시스템 / 환경
.env
.DS_Store
__pycache__/
*.pyc
.pytest_cache/
venv/
.venv/
node_modules/

# 로그
logs/*.log
logs/*.pid
server.log
everything-claude-code/

# DB 파일
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# 문서 / 미디어 (저작권·보안)
*.pdf
# EXCEPTION: Math Kangaroo past-paper PDFs ARE tracked so they reach every
# device. The daughter's Mac syncs via `git pull` only, so a gitignored PDF
# would leave the Past Papers feature showing "PDF not available". These are
# official public past papers used for personal practice.
!frontend/static/math/kangaroo/pdf/*.pdf
*.docx
*.pptx
*.xlsx
*.save
*.bak

# Kangaroo solutions (AI-generated, not tracked)
backend/data/math/kangaroo/solutions/

# Verifier debug dumps (regenerable via scripts/verify_g3_new_units.py --dump-skipped)
scripts/skipped_problems.json

# CKLA verifier reports (regenerable via scripts/verify_ckla_data.py --json)
reports/
design-ref/
